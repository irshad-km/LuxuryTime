<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luxury Watches - My Profile</title>
    
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        /* Custom Premium Styles */
        :root {
            --accent-purple: #5b42f3;
            --dark-surface: #1a1a1a;
            --input-bg: #121212;
            --border-color: #333333;
        }

        body {
            background-color: black;
            color: white;
            font-family: 'Inter', sans-serif;
        }

        /* Sidebar Navigation Items */
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 8px;
            color: #9ca3af;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .nav-item:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-item.active {
            background: rgba(91, 66, 243, 0.1);
            color: var(--accent-purple);
            border: 1px solid rgba(91, 66, 243, 0.2);
        }

        /* Form Controls */
        .label {
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6b7280;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .input-field {
            width: 100%;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            padding: 12px 16px;
            border-radius: 8px;
            color: white;
            outline: none;
            transition: border-color 0.2s;
        }

        .input-field:focus {
            border-color: var(--accent-purple);
        }

        /* Buttons */
        .btn-primary {
            background: var(--accent-purple);
            padding: 12px 28px;
            border-radius: 10px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: transform 0.2s, opacity 0.2s;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        .btn-secondary {
            background: #222;
            color: white;
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 500;
            transition: background 0.2s;
        }

        .btn-secondary:hover {
            background: #333;
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            padding: 8px 16px;
            border-radius: 6px;
            font-size: 0.875rem;
            color: #9ca3af;
            transition: all 0.2s;
        }

        .btn-outline:hover {
            border-color: white;
            color: white;
        }

        /* Custom Scrollbar for dark theme */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #000;
        }
        ::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 10px;
        }
    </style>
</head>
<body>

    <div class="flex min-h-screen">
        <aside class="w-72 border-r border-gray-800 p-8 flex flex-col justify-between sticky top-0 h-screen">
            <div>
                <div class="flex items-center gap-2 mb-12">
                    <i class="ph-bold ph-watch text-2xl text-[var(--accent-purple)]"></i>
                    <span class="font-bold tracking-widest uppercase text-sm">Luxury Watches</span>
                </div>

                <div class="flex items-center gap-3 mb-10">
                    <img src="<%= user.avatar %>" class="w-11 h-11 rounded-full border border-gray-700 object-cover">
                    <div>
                        <h3 class="text-sm font-bold truncate w-32"><%= user.name %></h3>
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider"><%= user.membership %></p>
                    </div>
                </div>

                <nav class="space-y-2">
                    <a href="/profile" class="nav-item active">
                        <i class="ph ph-user-circle text-xl"></i> My Profile
                    </a>
                    <a href="/orders" class="nav-item">
                        <i class="ph ph-shopping-cart-simple text-xl"></i> My Orders
                    </a>
                    <a href="/wallet" class="nav-item">
                        <i class="ph ph-wallet text-xl"></i> Wallet
                    </a>
                    <a href="/address" class="nav-item">
                        <i class="ph ph-map-pin text-xl"></i> Address
                    </a>
                    <a href="/refer" class="nav-item text-indigo-400">
                        <i class="ph ph-crown text-xl"></i> Refer & Earn
                    </a>
                </nav>
            </div>
            
            <a href="/logout" class="flex items-center gap-2 text-gray-500 hover:text-red-400 transition text-sm font-medium">
                <i class="ph ph-sign-out text-xl"></i> Logout
            </a>
        </aside>

        <main class="flex-1 p-16 bg-[#070707]">
            <header class="mb-12">
                <h1 class="text-4xl font-bold tracking-tight">My Profile</h1>
                <p class="text-gray-500 mt-2">Manage your personal information and security settings.</p>
            </header>

            <section class="bg-[#111111] rounded-2xl p-10 max-w-5xl border border-gray-800 shadow-2xl">
                
                <div class="flex items-center gap-8 mb-12 pb-12 border-b border-gray-800">
                    <div class="relative group">
                        <img src="<%= user.avatar %>" class="w-28 h-28 rounded-full object-cover border-4 border-[#222]">
                        <div class="absolute inset-0 flex items-center justify-center bg-black/40 rounded-full opacity-0 group-hover:opacity-100 transition cursor-pointer">
                            <i class="ph ph-camera text-2xl"></i>
                        </div>
                    </div>
                    <div>
                        <h2 class="text-3xl font-bold"><%= user.name %></h2>
                        <p class="text-gray-400 mb-5 text-lg"><%= user.email %></p>
                        <div class="flex gap-4">
                            <button class="btn-secondary">Upload New Photo</button>
                            <button class="btn-outline">Remove</button>
                        </div>
                    </div>
                </div>

                <form action="/profile/update" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <div class="md:col-span-2">
                        <label class="label">Full Name</label>
                        <input type="text" name="name" value="<%= user.name %>" class="input-field" placeholder="Enter your full name">
                    </div>

                    <div>
                        <label class="label">Phone Number</label>
                        <input type="text" name="phone" value="<%= user.phone %>" class="input-field" placeholder="+1 (000) 000-0000">
                    </div>

                    <div>
                        <label class="label">Email Address</label>
                        <input type="email" name="email" value="<%= user.email %>" class="input-field" placeholder="email@example.com">
                    </div>

                    <div>
                        <label class="label">Date of Birth</label>
                        <input type="date" name="dob" value="<%= user.dob %>" class="input-field">
                    </div>

                    <div>
                        <label class="label">Gender</label>
                        <select name="gender" class="input-field appearance-none">
                            <option value="Male" <%= user.gender === 'Male' ? 'selected' : '' %>>Male</option>
                            <option value="Female" <%= user.gender === 'Female' ? 'selected' : '' %>>Female</option>
                            <option value="Other" <%= user.gender === 'Other' ? 'selected' : '' %>>Other</option>
                        </select>
                    </div>

                    <div class="md:col-span-2 mt-8">
                        <h3 class="text-sm font-bold uppercase tracking-widest text-gray-600 mb-6">Security Settings</h3>
                        <div class="flex flex-wrap gap-4">
                            <button type="button" class="btn-outline flex items-center gap-2">
                                <i class="ph ph-lock"></i> Change Password
                            </button>
                            <button type="button" class="btn-outline flex items-center gap-2">
                                <i class="ph ph-envelope-simple"></i> Change Email
                            </button>
                        </div>
                    </div>

                    <div class="md:col-span-2 mt-10">
                        <button type="submit" class="btn-primary">
                            Save Changes <i class="ph-bold ph-check"></i>
                        </button>
                    </div>
                </form>
            </section>
        </main>
    </div>

</body>
</html>