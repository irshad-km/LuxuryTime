<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile | Luxury Watches</title>

    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --accent-purple: #5b42f3;
            --dark-surface: #111111;
            --input-bg: #1a1a1a;
            --border-color: #333333;
        }

        body {
            background-color: #070707;
            color: white;
            font-family: 'Inter', sans-serif;
            margin: 0;
        }

        /* Sidebar Navigation */
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 8px;
            color: #9ca3af;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .nav-item:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-item.active {
            background: rgba(91, 66, 243, 0.1);
            color: var(--accent-purple);
            border: 1px solid rgba(91, 66, 243, 0.2);
        }

        /* Form Styling */
        .label {
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6b7280;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .input-field {
            width: 100%;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            padding: 14px 16px;
            border-radius: 10px;
            color: white;
            outline: none;
            transition: all 0.2s;
        }

        .input-field:focus {
            border-color: var(--accent-purple);
            background: #222;
        }

        .input-field[readonly] {
            cursor: not-allowed;
            opacity: 0.7;
        }

        /* Buttons */
        .btn-primary {
            background: var(--accent-purple);
            color: white;
            padding: 14px 32px;
            border-radius: 10px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
            text-decoration: none;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(91, 66, 243, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 0.875rem;
            color: #9ca3af;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-outline:hover {
            border-color: white;
            color: white;
        }

        .letter-avatar {
            background-color: var(--accent-purple);
            color: white;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            text-transform: uppercase;
        }
    </style>
</head>

<body>

    <div class="flex min-h-screen">
        <aside class="w-72 border-r border-gray-800 p-8 flex flex-col justify-between sticky top-0 h-screen bg-black">
            <div>
                <a href="/" class="block group">
                    <div class="flex items-center gap-2 mb-12">
                        <i
                            class="ph-bold ph-watch text-2xl text-[var(--accent-purple)] group-hover:scale-110 transition-transform"></i>
                        <span
                            class="font-bold tracking-widest uppercase text-sm group-hover:text-[var(--accent-purple)] transition-colors">Luxury
                            Watches</span>
                    </div>
                </a>

                <div class="flex items-center gap-3 mb-10">
                    <% if (user.avatar && user.avatar !=="" && user.avatar !=="/default-avatar.png" ) { %>
                        <img src="<%= user.avatar %>"
                            class="w-11 h-11 rounded-full border border-gray-700 object-cover">
                        <% } else { %>
                            <div class="w-11 h-11 rounded-full letter-avatar text-lg border border-gray-700">
                                <%= user.fullname.charAt(0) %>
                            </div>
                            <% } %>
                                <div class="overflow-hidden">
                                    <h3 class="text-sm font-bold truncate w-32">
                                        <%= user.fullname %>
                                    </h3>
                                    <p class="text-[10px] text-gray-500 uppercase tracking-wider">
                                        <%= user.membership || 'Member' %>
                                    </p>
                                    <p style="color: white;"
                                        class="text-[14px] font-bold text-gray-500 uppercase tracking-wider">
                                        <strong>
                                            <%= user.referralCode %>
                                        </strong>
                                    </p>
                                </div>
                </div>

                <nav class="space-y-2">
                    <a href="/profile" class="nav-item active">
                        <i class="ph ph-user-circle text-xl"></i> My Profile
                    </a>
                    <a href="/orders" class="nav-item">
                        <i class="ph ph-shopping-cart-simple text-xl"></i> My Orders
                    </a>
                    <a href="/wallet" class="nav-item">
                        <i class="ph ph-wallet text-xl"></i> Wallet
                    </a>
                    <a href="/address" class="nav-item">
                        <i class="ph ph-map-pin text-xl"></i> Address
                    </a>
                </nav>
            </div>

            <div>
                <form id="logout-form" action="/logout" method="POST" style="display: none;"></form>
                <button type="button" onclick="handleLogout()"
                    class="w-full text-left px-4 py-3 rounded-lg text-sm text-red-400 hover:bg-red-500/10 hover:text-red-500 transition-all duration-200 flex items-center gap-3">
                    <i class="ph-bold ph-sign-out text-lg"></i> Logout
                </button>
            </div>
        </aside>

        <main class="flex-1 p-16">
            <div class="max-w-4xl mx-auto mb-6">
                <a href="/"
                    class="text-xs text-gray-500 hover:text-[var(--accent-purple)] flex items-center gap-2 transition-colors">
                    <i class="ph ph-arrow-left"></i> Back to Home
                </a>
            </div>

            <section
                class="bg-[var(--dark-surface)] rounded-2xl p-12 max-w-4xl border border-gray-800 mx-auto shadow-2xl">
                <div class="flex flex-col items-center mb-12">
                    <div class="mb-4">
                        <% if (user.avatar && user.avatar !=="" && user.avatar !=="/default-avatar.png" ) { %>
                            <img src="<%= user.avatar %>" id="avatar-preview"
                                class="w-28 h-28 rounded-full object-cover border-4 border-[#222]">
                            <% } else { %>
                                <div class="w-28 h-28 rounded-full letter-avatar text-4xl border-4 border-[#222]">
                                    <%= user.fullname.charAt(0) %>
                                </div>
                                <% } %>
                    </div>
                    <h1 class="text-3xl font-bold">My Profile</h1>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="label">Full Name</label>
                        <input type="text" value="<%= user.fullname %>" class="input-field" readonly>
                    </div>

                    <div>
                        <label class="label">Phone Number</label>
                        <input type="text" value="<%= user.phone %>" class="input-field" readonly>
                    </div>

                    <div>
                        <label class="label">Email Address</label>
                        <input type="email" value="<%= user.email %>" class="input-field" readonly>
                    </div>

                    <% if (!user.googleId) { %>
                        <div class="md:col-span-2 mt-8">
                            <h3 class="label mb-4">Security</h3>
                            <div class="flex gap-4">
                                <a href="/change-password" class="btn-outline">
                                    <i class="ph ph-lock"></i> Change Password
                                </a>
                                <a href="/change-email" class="btn-outline">
                                    <i class="ph ph-envelope"></i> Change Email
                                </a>
                            </div>
                        </div>
                        <% } %>

                            <div class="md:col-span-2 mt-12 flex justify-center">
                                <a href="/edit-profile" class="btn-primary">
                                    Edit Profile <i class="ph-bold ph-pencil-simple" style="margin-left: 8px;"></i>
                                </a>
                            </div>
                </div>
            </section>
        </main>
    </div>

    <script>
        function handleLogout() {
            Swal.fire({
                title: 'Logout?',
                text: "Are you sure you want to end your session?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5b42f3',
                cancelButtonColor: '#1a1a1a',
                confirmButtonText: 'Yes, Logout',
                cancelButtonText: 'Cancel',
                background: '#111111',
                color: '#ffffff',
                iconColor: '#5b42f3',
                backdrop: `rgba(0,0,0,0.8)`
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('logout-form').submit();
                }
            })
        }
    </script>

</body>

</html>