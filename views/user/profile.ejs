<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | Luxury Watches</title>

    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --accent-purple: #5b42f3;
            --dark-surface: #111111;
            --input-bg: #1a1a1a;
            --border-color: #333333;
        }

        body {
            background-color: #070707;
            color: white;
            font-family: 'Inter', sans-serif;
            margin: 0;
        }

        /* Sidebar Navigation */
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 8px;
            color: #9ca3af;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .nav-item:hover {
            color: white;
            background: rgba(255, 255, 255, 0.05);
        }

        .nav-item.active {
            background: rgba(91, 66, 243, 0.1);
            color: var(--accent-purple);
            border: 1px solid rgba(91, 66, 243, 0.2);
        }

        /* Form Styling */
        .label {
            display: block;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #6b7280;
            margin-bottom: 8px;
            font-weight: 600;
        }

        .input-field {
            width: 100%;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            padding: 14px 16px;
            border-radius: 10px;
            color: white;
            outline: none;
            transition: all 0.2s;
        }

        .input-field:focus {
            border-color: var(--accent-purple);
            background: #222;
        }

        /* Buttons */
        .btn-primary {
            background: var(--accent-purple);
            color: white;
            padding: 14px 32px;
            border-radius: 10px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            width: 100%;
            max-width: 280px;
        }

        .btn-primary:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(91, 66, 243, 0.3);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            padding: 10px 20px;
            border-radius: 8px;
            font-size: 0.875rem;
            color: #9ca3af;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
            text-decoration: none;
        }

        .btn-outline:hover {
            border-color: white;
            color: white;
        }

        .profile-pic-container {
            position: relative;
            width: 112px;
            height: 112px;
        }

        .edit-badge {
            position: absolute;
            bottom: 0;
            right: 0;
            background: var(--accent-purple);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid var(--dark-surface);
            cursor: pointer;
        }
    </style>
</head>

<body>

    <div class="flex min-h-screen">
        <aside class="w-72 border-r border-gray-800 p-8 flex flex-col justify-between sticky top-0 h-screen bg-black">
            <div>
                <div class="flex items-center gap-2 mb-12">
                    <i class="ph-bold ph-watch text-2xl text-[var(--accent-purple)]"></i>
                    <span class="font-bold tracking-widest uppercase text-sm">Luxury Watches</span>
                </div>

                <div class="flex items-center gap-3 mb-10">
                    <img src="<%= user.avatar %>" class="w-11 h-11 rounded-full border border-gray-700 object-cover">
                    <div>
                        <h3 class="text-sm font-bold truncate w-32">
                            <%= user.name %>
                        </h3>
                        <p class="text-[10px] text-gray-500 uppercase tracking-wider">
                            <%= user.membership %>
                        </p>
                    </div>
                </div>

                <nav class="space-y-2">
                    <a href="/profile" class="nav-item active">
                        <i class="ph ph-user-circle text-xl"></i> My Profile
                    </a>
                    <a href="/orders" class="nav-item">
                        <i class="ph ph-shopping-cart-simple text-xl"></i> My Orders
                    </a>
                    <a href="/wallet" class="nav-item">
                        <i class="ph ph-wallet text-xl"></i> Wallet
                    </a>
                    <a href="/address" class="nav-item">
                        <i class="ph ph-map-pin text-xl"></i> Address
                    </a>
                </nav>
            </div>

            <a href="/logout"
                class="flex items-center gap-2 text-gray-500 hover:text-red-400 transition text-sm font-medium">
                <i class="ph ph-sign-out text-xl"></i> Logout
            </a>
        </aside>

        <main class="flex-1 p-16">


            <section
                class="bg-[var(--dark-surface)] rounded-2xl p-12 max-w-4xl border border-gray-800 mx-auto shadow-2xl">

                <form action="/update-profile" method="POST" enctype="multipart/form-data">
                    <div class="flex flex-col items-center mb-12">
                        <div class="profile-pic-container mb-4">
                            <img src="<%= user.avatar %>"
                                class="w-28 h-28 rounded-full object-cover border-4 border-[#222]">
                            <label for="avatar-upload" class="edit-badge">
                                <i class="ph ph-pencil-simple text-white text-sm"></i>
                            </label>
                            <input type="file" id="avatar-upload" name="avatar" class="hidden">
                        </div>
                        <h1 class="text-3xl font-bold">Edit Profile</h1>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="label">Full Name</label>
                            <input type="text" name="name" value="<%= user.fullname %>" class="input-field"
                                placeholder="Alexander Pierce" readonly>
                        </div>

                        <div>
                            <label class="label">Phone Number</label>
                            <input type="text" name="phone" value="<%= user.phone  %>" class="input-field"
                                placeholder="+1 (555) 012-3456" readonly>
                        </div>

                        <div>
                            <label class="label">Email Address</label>
                            <input type="email" name="email" value="<%= user.email %>" class="input-field" readonly readonly>
                        </div>

                        <div>
                            <label class="label">Gender</label>
                            <select name="gender" class="input-field bg-gray-900/50 cursor-not-allowed" >
                                <option value="Male" <%=user.gender==='Male' ? 'selected' : '' %>>Male</option>
                                <option value="Female" <%=user.gender==='Female' ? 'selected' : '' %>>Female</option>
                            </select>

                            <input type="hidden" name="gender" value="<%= user.gender %>">
                        </div>

                        <div>
                            <label class="label">Date of Birth</label>
                            <input type="date" name="dob" value="<%= user.dob %>" class="input-field" >
                        </div>

                        <div class="md:col-span-2 mt-8">
                            <h3 class="label mb-4">Security</h3>
                            <div class="flex gap-4">
                                <a href="/change-password" class="btn-outline">
                                    <i class="ph ph-lock"></i> Change Password
                                </a>
                                <a href="/change-email" class="btn-outline">
                                    <i class="ph ph-envelope"></i> Change Email
                                </a>
                            </div>
                        </div>

                        <div class="md:col-span-2 mt-12 flex flex-col items-center">
                            <a href="/edit-profile" class="btn-primary">
                                Edit Profile <i class="ph-bold ph-check"></i>
                            </a>
                        </div>
                    </div>
                </form>
            </section>
        </main>
    </div>

</body>

</html>