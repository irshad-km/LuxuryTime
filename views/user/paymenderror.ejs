<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Failed | Luxury Time</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-black: #050505;
            --card-bg: rgba(15, 15, 15, 0.9);
            --accent-red: #ef4444;
            --accent-blue: #2563eb;
            --text-main: #ffffff;
            --text-muted: #a1a1aa;
            --border: #222222;
            --font-main: 'Plus Jakarta Sans', sans-serif;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: var(--bg-black);
            color: var(--text-main);
            font-family: var(--font-main);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        /* Ambient background glow */
        .glow {
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(239, 68, 68, 0.1) 0%, transparent 70%);
            z-index: 0;
            animation: floatGlow 8s ease-in-out infinite;
        }

        @keyframes floatGlow {
            0%, 100% { transform: translate(-10%, -10%); }
            50% { transform: translate(10%, 10%); }
        }

        .error-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 450px;
            padding: 24px;
        }

        .error-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 32px;
            padding: 48px 32px;
            text-align: center;
            backdrop-filter: blur(20px);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.6);
            /* Entry Animation */
            animation: cardEntrance 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        }

        @keyframes cardEntrance {
            from { opacity: 0; transform: scale(0.9) translateY(20px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }

        .icon-wrapper {
            width: 80px;
            height: 80px;
            background: rgba(239, 68, 68, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            border: 1px solid rgba(239, 68, 68, 0.2);
            position: relative;
        }

        /* SVG drawing animation */
        .icon-wrapper svg {
            width: 40px;
            height: 40px;
            stroke: var(--accent-red);
        }

        .path-line {
            stroke-dasharray: 50;
            stroke-dashoffset: 50;
            animation: drawLine 0.6s ease-out forwards;
            animation-delay: 0.5s;
        }

        @keyframes drawLine {
            to { stroke-dashoffset: 0; }
        }

        .icon-circle {
            stroke-dasharray: 100;
            stroke-dashoffset: 100;
            animation: drawLine 0.8s ease-out forwards;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 12px;
            letter-spacing: -0.02em;
        }

        p.desc {
            color: var(--text-muted);
            font-size: 15px;
            line-height: 1.6;
            margin-bottom: 32px;
        }

        .error-details {
            background: rgba(239, 68, 68, 0.05);
            border: 1px dashed rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            padding: 14px;
            font-family: 'Courier New', monospace;
            font-size: 13px;
            color: #f87171;
            margin-bottom: 32px;
            animation: fadeIn 1s ease-in;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .actions {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .btn {
            padding: 16px;
            border-radius: 16px;
            font-weight: 600;
            font-size: 15px;
            text-decoration: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            text-align: center;
        }

        .btn-primary {
            background: var(--accent-blue);
            color: white;
            border: none;
            box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            background: #1d4ed8;
            box-shadow: 0 15px 30px rgba(37, 99, 235, 0.3);
        }

        .btn-secondary {
            background: transparent;
            color: var(--text-muted);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.05);
            color: white;
            border-color: #444;
        }

        .support-text {
            margin-top: 24px;
            font-size: 12px;
            color: var(--text-muted);
        }
    </style>
</head>
<body>

<div class="glow"></div>

<div class="error-container">
    <div class="error-card">
        <div class="icon-wrapper">
            <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle class="icon-circle" cx="12" cy="12" r="10"></circle>
                <line class="path-line" x1="15" y1="9" x2="9" y2="15"></line>
                <line class="path-line" x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
        </div>

        <h1>Payment Declined</h1>
        <p class="desc">We couldn't process your transaction. Please check your details or try a different payment method.</p>
        
        <% if (locals.message) { %>
            <div class="error-details">
                ERROR_CODE: <%= message %>
            </div>
        <% } %>

        <div class="actions">
            <a href="/checkout" class="btn btn-primary">Try Again</a>
            <a href="/cart" class="btn btn-secondary">Return to Cart</a>
        </div>

        <p class="support-text">Need help? support@luxurytime.com</p>
    </div>
</div>

</body>
</html>