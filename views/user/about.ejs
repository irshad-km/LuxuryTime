<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Heritage | Infinity Edition</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Syncopate:wght@700&family=Playfair+Display:ital,wght@0,400;1,900&family=Inter:wght@100;300;600&display=swap" rel="stylesheet">
    
    <style>
        :root { --accent: #3b82f6; --gold: #c5a059; }
        body { background: #000; color: #fff; font-family: 'Inter', sans-serif; overflow-x: hidden; cursor: none; }
        
        /* Custom High-Precision Cursor */
        #cursor-ring {
            width: 40px; height: 40px; border: 1px solid rgba(255,255,255,0.2);
            border-radius: 50%; position: fixed; pointer-events: none; z-index: 9999;
            transition: all 0.1s ease-out;
        }
        #cursor-dot {
            width: 4px; height: 4px; background: var(--accent);
            border-radius: 50%; position: fixed; pointer-events: none; z-index: 10000;
        }

        /* Luxury Typography */
        .chrono-header { font-family: 'Syncopate', sans-serif; letter-spacing: -0.05em; line-height: 0.8; }
        .serif-italic { font-family: 'Playfair Display', serif; font-style: italic; }

        /* Smooth Canvas Background */
        #canvas-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; }

        /* Glass Refraction Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.01);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }
        .glass-card:hover {
            background: rgba(59, 130, 246, 0.05);
            border-color: var(--accent);
            transform: translateY(-15px) scale(1.02);
        }

        /* Scroll Progress Bar */
        #progress-wrap {
            position: fixed; right: 40px; top: 50%; transform: translateY(-50%);
            height: 30vh; width: 2px; background: rgba(255,255,255,0.1); z-index: 100;
        }
        #progress-bar { width: 100%; height: 0%; background: var(--accent); box-shadow: 0 0 15px var(--accent); }

        /* Image Reveal Mask */
        .img-reveal { clip-path: inset(0 100% 0 0); transition: clip-path 1.2s cubic-bezier(0.77, 0, 0.175, 1); }
        .img-reveal.active { clip-path: inset(0 0% 0 0); }
    </style>
</head>
<body>

    <div id="cursor-ring"></div>
    <div id="cursor-dot"></div>
    <div id="progress-wrap"><div id="progress-bar"></div></div>
    <div id="canvas-container"></div>

    <nav class="fixed w-full z-50 p-10 flex justify-between items-center mix-blend-difference">
        <a href="/" class="text-xl font-bold tracking-[0.5em] uppercase">Luxury Time</a>
        <div class="text-[10px] tracking-[0.3em] uppercase opacity-50 hidden md:block">Geneva // Switzerland</div>
    </nav>

    <section class="h-screen flex flex-col items-center justify-center text-center px-6">
        <div class="z-10">
            <span class="text-accent tracking-[0.8em] text-[10px] font-bold uppercase mb-6 block" data-aos="fade-down">The Apex of Horology</span>
            <h1 class="chrono-header text-[12vw] md:text-[10vw] font-black mb-6" id="hero-title">PRECISION</h1>
            <h2 class="serif-italic text-3xl md:text-6xl opacity-40">Built for the Infinite.</h2>
            <div class="mt-16" data-aos="fade-up" data-aos-delay="800">
                <button class="px-12 py-5 border border-white/20 rounded-full text-[10px] uppercase tracking-[0.5em] hover:bg-white hover:text-black transition-all duration-700">
                    Begin the Journey
                </button>
            </div>
        </div>
    </section>

    <section class="py-40 px-10 md:px-32 grid md:grid-cols-2 gap-32 items-center">
        <div class="img-reveal" id="trigger-1">
            <img src="https://images.unsplash.com/photo-1547996160-81dfa63595aa?auto=format&fit=crop&q=100" 
                 class="rounded-sm grayscale hover:grayscale-0 transition duration-1000 scale-110" id="parallax-img">
        </div>
        <div data-aos="fade-left">
            <h2 class="text-6xl serif-italic mb-10">Beyond <br><span class="text-accent italic">Human Limits.</span></h2>
            <p class="text-xl text-gray-500 font-light leading-relaxed mb-10">
                Our craftsmen spend 400 hours on a single dial. It is not about telling time; it is about honoring the seconds that define your life.
            </p>
            <div class="h-[1px] w-full bg-white/10 mb-10"></div>
            <div class="flex gap-20">
                <div><p class="text-4xl font-light tracking-tighter">0.001s</p><p class="text-[10px] text-gray-500 uppercase tracking-widest">Accuracy</p></div>
                <div><p class="text-4xl font-light tracking-tighter">∞L</p><p class="text-[10px] text-gray-500 uppercase tracking-widest">Durability</p></div>
            </div>
        </div>
    </section>

    <section class="py-32 bg-[#050505] px-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-1">
            <% const specs = [
                { t: "The Movement", d: "Proprietary V-12 heart, hand-calibrated over 30 days." },
                { t: "The Crystal", d: "Dual-domed sapphire with molecular anti-reflective coating." },
                { t: "The Forging", d: "Cold-pressed 904L steel, polished to a mirror finish." }
            ] %>
            <% specs.forEach((s, i) => { %>
                <div class="glass-card p-20 h-[500px] flex flex-col justify-between" data-aos="fade-up" data-aos-delay="<%= i*200 %>">
                    <span class="text-accent font-bold tracking-widest text-xs">SPEC_0<%= i+1 %></span>
                    <div>
                        <h3 class="text-3xl mb-6 uppercase tracking-tighter font-bold"><%= s.t %></h3>
                        <p class="text-gray-500 leading-relaxed font-light"><%= s.d %></p>
                    </div>
                </div>
            <% }) %>
        </div>
    </section>

    <section class="py-40 relative">
        <div class="text-center mb-32">
            <h2 class="text-7xl chrono-header opacity-10">CHRONOLOGY</h2>
        </div>
        <div class="max-w-4xl mx-auto px-10 relative">
            <div class="absolute left-1/2 -translate-x-1/2 h-full w-[1px] bg-gradient-to-b from-transparent via-accent to-transparent opacity-30"></div>
            
            <% const timeline = [
                { y: '1985', m: 'The First Forge', pos: 'left' },
                { y: '2010', m: 'Mechanical Revolution', pos: 'right' },
                { y: '2026', m: 'The Virtual Frontier', pos: 'left' }
            ] %>

            <% timeline.forEach(item => { %>
                <div class="flex items-center justify-between mb-40 w-full <%= item.pos === 'right' ? 'flex-row-reverse' : '' %>">
                    <div class="w-[42%] <%= item.pos === 'right' ? 'text-left' : 'text-right' %>" data-aos="zoom-in-<%= item.pos %>">
                        <h3 class="text-5xl font-black text-accent mb-4 tracking-tighter"><%= item.y %></h3>
                        <p class="text-gray-400 uppercase tracking-[0.3em] text-[10px]"><%= item.m %></p>
                    </div>
                    <div class="w-3 h-3 rounded-full bg-accent shadow-[0_0_20px_#3b82f6] z-10"></div>
                    <div class="w-[42%]"></div>
                </div>
            <% }) %>
        </div>
    </section>

    <section class="h-screen flex flex-col items-center justify-center bg-black relative">
        <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
        <h2 class="text-7xl md:text-[12vw] chrono-header text-center z-10 mix-blend-difference" data-aos="zoom-out">TIME IS <br> YOURS.</h2>
        <button class="mt-20 px-20 py-8 bg-accent rounded-full font-bold tracking-[1em] text-[10px] z-10 uppercase hover:scale-110 transition-transform">
            Enter the Vault
        </button>
    </section>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        gsap.registerPlugin(ScrollTrigger);
        AOS.init({ duration: 1500, once: false });

        // 1. MAGNETIC CURSOR LOGIC
        const ring = document.getElementById('cursor-ring');
        const dot = document.getElementById('cursor-dot');
        window.addEventListener('mousemove', (e) => {
            gsap.to(dot, { x: e.clientX, y: e.clientY, duration: 0 });
            gsap.to(ring, { x: e.clientX - 20, y: e.clientY - 20, duration: 0.15 });
        });

        // 2. THREE.JS STARFIELD (The Immersion)
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.getElementById('canvas-container').appendChild(renderer.domElement);

        const geo = new THREE.BufferGeometry();
        const pos = new Float32Array(5000 * 3);
        for(let i=0; i<5000*3; i++) pos[i] = (Math.random() - 0.5) * 12;
        geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
        const mat = new THREE.PointsMaterial({ size: 0.003, color: 0xffffff, transparent: true, opacity: 0.3 });
        const stars = new THREE.Points(geo, mat);
        scene.add(stars);
        camera.position.z = 2;

        function animate() {
            requestAnimationFrame(animate);
            stars.rotation.y += 0.0005;
            renderer.render(scene, camera);
        }
        animate();

        // 3. GSAP SCROLL ENHANCEMENTS
        // Text Scramble on Load
        const solve = (el) => {
            const chars = '0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ';
            const originalText = el.innerText;
            let iteration = 0;
            const interval = setInterval(() => {
                el.innerText = originalText.split("").map((l, i) => {
                    if(i < iteration) return originalText[i];
                    return chars[Math.floor(Math.random() * 36)];
                }).join("");
                if(iteration >= originalText.length) clearInterval(interval);
                iteration += 1/4;
            }, 40);
        }
        window.onload = () => solve(document.getElementById('hero-title'));

        // Progress Bar & Image Reveal
        ScrollTrigger.create({
            trigger: "body",
            start: "top top",
            end: "bottom bottom",
            onUpdate: (self) => {
                document.getElementById('progress-bar').style.height = (self.progress * 100) + "%";
            }
        });

        ScrollTrigger.create({
            trigger: "#trigger-1",
            start: "top 70%",
            onEnter: () => document.getElementById('trigger-1').classList.add('active')
        });

        gsap.to("#parallax-img", {
            y: -100,
            scrollTrigger: { trigger: "#trigger-1", scrub: true }
        });
    </script>
</body>
</html>