<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | Luxury Watches</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --bg-dark: #0a0a0a;
            --card-dark: #161616;
            --input-bg: #1f1f1f;
            --accent-purple: #5b42f3;
            --text-gray: #a0a0a0;
            --white: #ffffff;
            --border-color: #2a2a2a;
            --error-red: #ff4d4d;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--white);
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        nav {
            width: 100%;
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
            border-bottom: 1px solid #222;
        }

        .logo {
            font-weight: 700;
            letter-spacing: 1px;
            font-size: 1.2rem;
        }

        .nav-links a {
            color: var(--text-gray);
            text-decoration: none;
            margin: 0 15px;
            font-size: 14px;
        }

        .nav-icons i {
            margin-left: 20px;
            cursor: pointer;
            color: var(--text-gray);
        }

        .wrapper {
            width: 100%;
            max-width: 500px;
            margin-top: 40px;
            padding: 20px;
        }

        .card {
            background-color: var(--card-dark);
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 1px solid #222;
        }

        .profile-pic-container {
            position: relative;
            width: 100px;
            height: 100px;
            margin: 0 auto 20px auto;
        }

        .profile-pic {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #333;
        }

        .edit-badge {
            position: absolute;
            bottom: 0;
            right: 0;
            background: var(--accent-purple);
            width: 28px;
            height: 28px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            border: 2px solid var(--card-dark);
            color: white;
        }

        h1 {
            font-size: 26px;
            margin-bottom: 30px;
            font-weight: 600;
        }

        .form-group {
            text-align: left;
            margin-bottom: 20px;
            position: relative;
        }

        label {
            display: block;
            font-size: 12px;
            color: var(--text-gray);
            margin-bottom: 8px;
            font-weight: 500;
        }

        input {
            width: 100%;
            padding: 14px;
            background-color: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: white;
            box-sizing: border-box;
            outline: none;
            font-size: 14px;
            transition: border-color 0.2s;
        }

        input:focus {
            border-color: var(--accent-purple);
        }

        /* Fixed Placeholder Color */
        input::placeholder {
            color: #ffffff !important;
            opacity: 1 !important;
        }

        .error-text {
            color: var(--error-red);
            font-size: 11px;
            margin-top: 5px;
            display: none;
        }

        form.was-validated input:invalid {
            border-color: var(--error-red);
        }

        form.was-validated input:invalid ~ .error-text {
            display: block;
        }

        /* CORRECTED ALIGNMENT: Side-by-Side Buttons */
        .button-group {
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }

        .btn-primary {
            flex: 2; /* Save changes takes more space */
            padding: 14px;
            background-color: var(--accent-purple);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            font-size: 14px;
            transition: 0.3s;
        }

        .btn-secondary {
            flex: 1; /* Back button is smaller */
            padding: 14px;
            background-color: transparent;
            color: var(--white);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            font-weight: 500;
            cursor: pointer;
            font-size: 14px;
            text-decoration: none;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 6px;
            transition: 0.3s;
        }

        .btn-secondary:hover {
            background-color: rgba(255, 255, 255, 0.05);
        }

        footer {
            margin-top: auto;
            color: #444;
            font-size: 11px;
            padding: 30px 0;
        }
    </style>
</head>

<body>

    <nav>
        <div class="logo">⌚ LUXURY WATCHES</div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
            <a href="/about">About</a>
        </div>
        <div class="nav-icons">
            <i class="fa-regular fa-heart"></i>
            <i class="fa-solid fa-bag-shopping"></i>
            <i class="fa-regular fa-user"></i>
        </div>
    </nav>

    <div class="wrapper">
        <div class="card">
            <div class="profile-pic-container">
                <img id="profilePreview" src="<%= user.avatar || '/default-avatar.png' %>" alt="Profile" class="profile-pic">
                <label for="file-upload" class="edit-badge">
                    <i class="fa-solid fa-pen"></i>
                </label>
            </div>

            <h1>Edit Profile</h1>

            <form action="/edit-profile" method="POST" enctype="multipart/form-data" id="editProfileForm" novalidate>
                <input id="file-upload" type="file" name="avatar" accept="image/*" hidden>

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="fullname" value="<%= user.fullname %>" placeholder="Alexander Pierce" required minlength="3">
                    <div class="error-text">Min 3 characters required.</div>
                </div>

                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" name="phone" value="<%= user.phone %>" placeholder="10-digit number" required pattern="[0-9]{10}">
                    <div class="error-text">Enter a valid 10-digit number.</div>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn-primary">
                        Save Changes <i class="fa-solid fa-check"></i>
                    </button>
                    <a href="/profile" class="btn-secondary">
                        Back
                    </a>
                </div>
            </form>
        </div>
    </div>

    <footer>
        © 2026 Luxe Watches Inc. All rights reserved.
    </footer>

    <script>
        const fileInput = document.getElementById("file-upload");
        const previewImg = document.getElementById("profilePreview");
        const form = document.getElementById("editProfileForm");

        fileInput.addEventListener("change", () => {
            const file = fileInput.files[0];
            if (file) {
                previewImg.src = URL.createObjectURL(file);
            }
        });

        form.addEventListener("submit", (e) => {
            if (!form.checkValidity()) {
                e.preventDefault();
                e.stopPropagation();
            }
            form.classList.add("was-validated");
        });
    </script>

</body>

</html>