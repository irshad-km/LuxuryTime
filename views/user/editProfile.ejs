<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | Luxury Watches</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --bg-dark: #0a0a0a;
            --card-dark: #161616;
            --input-bg: #1f1f1f;
            --accent-purple: #5b42f3;
            --text-gray: #a0a0a0;
            --white: #ffffff;
            --border-color: #2a2a2a;
            --error-red: #ff4d4d;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--white);
            font-family: 'Inter', sans-serif;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }

        nav {
            width: 100%;
            padding: 20px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-sizing: border-box;
            border-bottom: 1px solid #222;
        }

        .logo { font-weight: 700; letter-spacing: 1px; font-size: 1.2rem; }

        .wrapper {
            width: 100%;
            max-width: 500px;
            margin-top: 40px;
            padding: 20px;
        }

        .card {
            background-color: var(--card-dark);
            border-radius: 16px;
            padding: 40px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
            border: 1px solid #222;
        }

        .profile-pic-container {
            margin-bottom: 25px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 15px;
            width: 100%;
        }

        .profile-pic {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #333;
            background-color: #222;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            text-transform: uppercase;
            color: white;
            font-size: 40px;
        }

        .letter-avatar {
            background-color: var(--accent-purple);
        }

        .image-action-btns {
            display: flex;
            justify-content: center;
            gap: 12px;
        }

        .img-btn {
            padding: 10px 18px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 1px solid var(--border-color);
        }

        .btn-add-img { background-color: var(--accent-purple); color: white; border: none; }
        .btn-delete-img { background-color: transparent; color: var(--error-red); border: 1px solid var(--error-red); }

        .img-btn:hover { opacity: 0.8; transform: translateY(-2px); }

        h1 { font-size: 26px; margin-bottom: 30px; }
        .form-group { text-align: left; margin-bottom: 20px; position: relative; }
        label { display: block; font-size: 12px; color: var(--text-gray); margin-bottom: 8px; }
        
        input {
            width: 100%;
            padding: 14px;
            background-color: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: white;
            outline: none;
            box-sizing: border-box;
        }

        input:focus { border-color: var(--accent-purple); }

        .error-message {
            color: var(--error-red);
            font-size: 11px;
            margin-top: 5px;
            display: none;
        }

        .button-group { display: flex; gap: 12px; margin-top: 20px; }
        .btn-primary { flex: 2; padding: 14px; background-color: var(--accent-purple); color: white; border: none; border-radius: 10px; font-weight: 600; cursor: pointer; }
        .btn-secondary { flex: 1; padding: 14px; border: 1px solid var(--border-color); color: white; text-decoration: none; border-radius: 10px; display: flex; align-items: center; justify-content: center; }

        footer { margin-top: auto; color: #444; font-size: 11px; padding: 30px 0; }
    </style>
</head>

<body>

    <nav>
        <div class="logo">⌚ LUXURY WATCHES</div>
    </nav>

    <div class="wrapper">
        <div class="card">
            <div class="profile-pic-container">
                <div id="avatar-wrapper">
                    <% if (user.avatar && user.avatar.trim() !== "" && user.avatar !== "/default-avatar.png") { %>
                        <img id="profilePreview" src="<%= user.avatar %>" class="profile-pic">
                    <% } else { %>
                        <div id="profilePreview" class="profile-pic letter-avatar">
                            <%= user.fullname.charAt(0).toUpperCase() %>
                        </div>
                    <% } %>
                </div>
                
                <div class="image-action-btns">
                    <label for="file-upload" class="img-btn btn-add-img">
                        <i class="fa-solid fa-plus"></i> Add
                    </label>
                    <button type="button" id="remove-pic-btn" class="img-btn btn-delete-img">
                        <i class="fa-solid fa-trash"></i> Delete
                    </button>
                </div>
            </div>

            <h1>Edit Profile</h1>

            <form action="/edit-profile" method="POST" enctype="multipart/form-data" id="editProfileForm">
                <input id="file-upload" type="file" name="avatar" accept="image/*" hidden>
                <input type="hidden" name="removeAvatar" id="removeAvatarInput" value="false">

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" id="fullname" name="fullname" value="<%= user.fullname %>" placeholder="Enter full name" maxlength="20">
                    <small class="error-message" id="nameError">Name must be 3-20 characters and contain no numbers.</small>
                </div>

                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" id="phone" name="phone" value="<%= user.phone %>" placeholder="10-digit number" maxlength="10">
                    <small class="error-message" id="phoneError">Please enter a valid 10-digit phone number.</small>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn-primary">Save Changes</button>
                    <a href="/profile" class="btn-secondary">Back</a>
                </div>
            </form>
        </div>
    </div>

    <footer>© 2026 Luxe Watches Inc. All rights reserved.</footer>

    <script>
        const fileInput = document.getElementById("file-upload");
        const avatarWrapper = document.getElementById("avatar-wrapper");
        const removeBtn = document.getElementById("remove-pic-btn");
        const removeInput = document.getElementById("removeAvatarInput");
        const editForm = document.getElementById("editProfileForm");
        const nameInput = document.getElementById("fullname");
        const phoneInput = document.getElementById("phone");
        
        const userInitial = "<%= user.fullname.charAt(0).toUpperCase() %>";

        fileInput.addEventListener("change", function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    avatarWrapper.innerHTML = `<img src="${e.target.result}" class="profile-pic">`;
                    removeInput.value = "false";
                }
                reader.readAsDataURL(file);
            }
        });

        removeBtn.addEventListener("click", function() {
            avatarWrapper.innerHTML = `<div class="profile-pic letter-avatar">${userInitial}</div>`;
            fileInput.value = "";
            removeInput.value = "true";
        });

        // Real-time: Remove numbers from name
        nameInput.addEventListener("input", function() {
            this.value = this.value.replace(/[0-9]/g, "");
        });

        // Real-time: Remove non-numbers from phone
        phoneInput.addEventListener("input", function() {
            this.value = this.value.replace(/[^0-9]/g, "");
        });

        // --- FINAL SUBMISSION VALIDATION ---
        editForm.addEventListener("submit", function(e) {
            let isValid = true;
            
            const nameError = document.getElementById("nameError");
            const phoneError = document.getElementById("phoneError");

            // Reset UI
            nameError.style.display = "none";
            phoneError.style.display = "none";
            nameInput.style.borderColor = "var(--border-color)";
            phoneInput.style.borderColor = "var(--border-color)";

            // --- Name Check ---
            const nameValue = nameInput.value.trim();
            if (nameValue === "" || nameValue.length < 3) {
                nameError.textContent = "Please enter a valid name (min 3 chars).";
                nameError.style.display = "block";
                nameInput.style.borderColor = "var(--error-red)";
                isValid = false;
            }

            // --- Phone Check (Strong Validation) ---
            const phoneValue = phoneInput.value.trim();
            
            // Check if all digits are the same (e.g., 9999999999)
            const isRepeating = /^(\d)\1{9}$/.test(phoneValue);
            
            if (phoneValue.length !== 10) {
                phoneError.textContent = "Phone number must be exactly 10 digits.";
                phoneError.style.display = "block";
                phoneInput.style.borderColor = "var(--error-red)";
                isValid = false;
            } else if (phoneValue.startsWith("0")) {
                phoneError.textContent = "Phone number cannot start with 0.";
                phoneError.style.display = "block";
                phoneInput.style.borderColor = "var(--error-red)";
                isValid = false;
            } else if (isRepeating) {
                phoneError.textContent = "Please enter a valid phone number, not repeating digits.";
                phoneError.style.display = "block";
                phoneInput.style.borderColor = "var(--error-red)";
                isValid = false;
            }

            if (!isValid) {
                e.preventDefault();
            }
        });
    </script>

</body>
</html>