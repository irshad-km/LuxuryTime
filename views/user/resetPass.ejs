<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Change Password | Luxury Watches</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root {
            --bg-color: #0a0a0a;
            --card-bg: #141414;
            --primary-accent: #6366f1; /* Purple/Indigo accent from screenshot */
            --text-main: #ffffff;
            --text-muted: #a0a0a0;
            --input-bg: #1f1f1f;
            --border-color: #2a2a2a;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navbar Placeholder to match screenshot */
        .navbar {
            padding: 20px 50px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-color);
        }

        .container {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 20px;
        }

        .change-card {
            width: 100%;
            max-width: 450px;
            background: var(--card-bg);
            padding: 40px;
            border-radius: 16px;
            border: 1px solid var(--border-color);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13px;
            margin-bottom: 25px;
            transition: color 0.3s;
        }

        .back-link:hover { color: white; }
        .back-link i { margin-right: 8px; }

        h2 { font-size: 28px; margin: 0 0 10px 0; font-weight: 600; }
        .subtitle { color: var(--text-muted); font-size: 14px; margin-bottom: 30px; line-height: 1.5; }

        .form-group { margin-bottom: 20px; }
        label { display: block; font-size: 13px; color: var(--text-muted); margin-bottom: 8px; }

        .input-wrapper { position: relative; }
        input {
            width: 100%;
            padding: 14px 16px;
            background: var(--input-bg);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: white;
            box-sizing: border-box;
            outline: none;
            transition: all 0.3s;
        }

        input:focus { border-color: var(--primary-accent); box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2); }

        .toggle-password {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: #555;
            cursor: pointer;
        }

        .btn-save {
            width: 100%;
            padding: 14px;
            background: var(--primary-accent);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
            transition: opacity 0.3s;
        }

        .btn-save:hover { opacity: 0.9; }

        .security-requirements {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid var(--border-color);
        }

        .req-title {
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 15px;
            color: var(--primary-accent);
        }

        .req-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 8px;
        }

        .req-item i { font-size: 14px; color: #333; }
        
        .error-message { color: #ef4444; font-size: 13px; margin-bottom: 15px; text-align: center; }
    </style>
</head>
<body>

    <div class="container">
        <div class="change-card">
            <a href="/profile" class="back-link">
                <i class="fa-solid fa-arrow-left"></i> Back to Account Settings
            </a>

            <h2>Change Password</h2>
            <p class="subtitle">Update your account password securely to keep your collection safe.</p>

            <% if (locals.message) { %>
                <div class="error-message"><%= message %></div>
            <% } %>

            <form id="changePasswordForm" action="/change-password" method="POST">
                <div class="form-group">
                    <label>Current Password</label>
                    <div class="input-wrapper">
                        <input type="password" name="currentPassword" id="currentPassword" placeholder="Enter current password" required>
                        <i class="fa-regular fa-eye-slash toggle-password" onclick="togglePass('currentPassword', this)"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label>New Password</label>
                    <div class="input-wrapper">
                        <input type="password" name="newPassword" id="newPassword" placeholder="Enter new password" required>
                        <i class="fa-regular fa-eye-slash toggle-password" onclick="togglePass('newPassword', this)"></i>
                    </div>
                </div>

                <div class="form-group">
                    <label>Confirm New Password</label>
                    <div class="input-wrapper">
                        <input type="password" name="confirmPassword" id="confirmPassword" placeholder="Confirm new password" required>
                        <i class="fa-regular fa-eye-slash toggle-password" onclick="togglePass('confirmPassword', this)"></i>
                    </div>
                </div>

                <button type="submit" class="btn-save">
                    SAVE CHANGES <i class="fa-solid fa-check-circle"></i>
                </button>
            </form>

            <div class="security-requirements">
                <div class="req-title"><i class="fa-solid fa-shield-halved"></i> Security Requirements</div>
                <div class="req-item"><i class="fa-regular fa-circle"></i> Use at least 8 characters</div>
                <div class="req-item"><i class="fa-regular fa-circle"></i> Mix uppercase, lowercase, numbers & symbols</div>
                <div class="req-item"><i class="fa-regular fa-circle"></i> Avoid reusing old passwords</div>
            </div>
        </div>
    </div>

    <script>
        function togglePass(inputId, icon) {
            const input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace('fa-eye-slash', 'fa-eye');
            } else {
                input.type = "password";
                icon.classList.replace('fa-eye', 'fa-eye-slash');
            }
        }

        document.getElementById('changePasswordForm').onsubmit = function(e) {
            const newPass = document.getElementById('newPassword').value;
            const confirmPass = document.getElementById('confirmPassword').value;

            if (newPass.length < 8) {
                e.preventDefault();
                alert("New password must be at least 8 characters long.");
                return;
            }

            if (newPass !== confirmPass) {
                e.preventDefault();
                alert("New passwords do not match!");
            }
        };
    </script>
</body>
</html>