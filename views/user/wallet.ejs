<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>My Wallet | Luxury Watches</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

  <style>
    :root {
      --accent-purple: #5b42f3;
      --dark-surface: #111111;
      --border-color: #333333;
      --default-blue-glow: rgba(91, 66, 243, 0.15);
    }

    body {
      background-color: #070707;
      color: white;
      font-family: 'Inter', sans-serif;
      margin: 0;
    }

    /* Sidebar Styles */
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 8px;
      color: #9ca3af;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .nav-item:hover {
      color: white;
      background: rgba(255, 255, 255, 0.05);
    }

    .nav-item.active {
      background: rgba(91, 66, 243, 0.1);
      color: var(--accent-purple);
      border: 1px solid rgba(91, 66, 243, 0.2);
    }

    /* Glass Cards */
    .glass-card {
      background: var(--dark-surface);
      border: 1px solid var(--border-color);
      border-radius: 24px;
      backdrop-filter: blur(10px);
    }

    .balance-card {
      background: linear-gradient(145deg, #111111 0%, #161625 100%);
      border-color: var(--accent-purple);
      box-shadow: 0 10px 30px var(--default-blue-glow);
    }

    .btn-add {
      background: var(--accent-purple);
      color: #fff;
      border-radius: 10px;
      padding: 12px 24px;
      font-weight: 600;
      border: none;
      transition: 0.3s;
    }

    .btn-add:hover {
      opacity: 0.9;
      transform: translateY(-2px);
    }

    /* Custom Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #070707; }
    ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
  </style>
</head>

<body>

  <div class="flex min-h-screen">
    <aside class="w-72 border-r border-gray-800 p-8 flex flex-col justify-between sticky top-0 h-screen bg-black">
      <div>
        <a href="/" class="block group">
          <div class="flex items-center gap-2 mb-12">
            <i class="ph-bold ph-watch text-2xl text-[var(--accent-purple)] group-hover:scale-110 transition-transform"></i>
            <span class="font-bold tracking-widest uppercase text-sm group-hover:text-[var(--accent-purple)] transition-colors">Luxury Watches</span>
          </div>
        </a>

           <div class="flex items-center gap-3 mb-10">
                    <% if (user.avatar && user.avatar !=="" && user.avatar !=="/default-avatar.png" ) { %>
                        <img src="<%= user.avatar %>"
                            class="w-11 h-11 rounded-full border border-gray-700 object-cover">
                        <% } else { %>
                            <div class="w-11 h-11 rounded-full letter-avatar text-lg border border-gray-700">
                                <%= user.fullname.charAt(0) %>
                            </div>
                            <% } %>
                                <div class="overflow-hidden">
                                    <h3 class="text-sm font-bold truncate w-32">
                                        <%= user.fullname %>
                                    </h3>
                                    <p class="text-[10px] text-gray-500 uppercase tracking-wider">
                                        <%= user.email %>
                                    </p>
                                    <p style="color: white;"
                                        class="text-[14px] font-bold text-gray-500 uppercase tracking-wider">
                                        <strong>
                                            <%= user.referralCode %>
                                        </strong>
                                    </p>
                                </div>
                </div>

        <nav class="space-y-2">
          <a href="/profile" class="nav-item"><i class="ph ph-user-circle text-xl"></i> My Profile</a>
          <a href="/orders" class="nav-item"><i class="ph ph-shopping-cart-simple text-xl"></i> My Orders</a>
          <a href="/wallet" class="nav-item active"><i class="ph ph-wallet text-xl"></i> Wallet</a>
          <a href="/address" class="nav-item"><i class="ph ph-map-pin text-xl"></i> Address</a>
        </nav>
      </div>
      <div>
        <form id="logout-form" action="/logout" method="POST" style="display: none;"></form>
        <button type="button" onclick="handleLogout()"
          class="w-full text-left px-4 py-3 rounded-lg text-sm text-red-400 hover:bg-red-500/10 hover:text-red-500 transition-all duration-200 flex items-center gap-3">
          <i class="ph-bold ph-sign-out text-lg"></i> Logout
        </button>
      </div>
    </aside>

    <main class="flex-1 p-16 bg-[#070707]">
      <div class="container-fluid max-w-5xl mx-auto">
        
        <div class="mb-6">
          <a href="/" class="text-xs text-gray-500 hover:text-[var(--accent-purple)] flex items-center gap-2 transition-colors">
            <i class="ph ph-arrow-left"></i> Back to Home
          </a>
        </div>

        <header class="mb-12">
          <h1 class="text-4xl font-bold mb-2">My Wallet</h1>
          <p class="text-gray-500">Manage your balance and transaction history</p>
        </header>

        <div class="glass-card balance-card p-10 mb-12 flex justify-between items-center">
          <div>
            <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 font-bold mb-3">Available Balance</p>
            <div class="flex items-baseline">
              <span class="text-5xl font-bold tracking-tight">₹<%= wallet.balance.toLocaleString('en-IN') %></span>
              <span class="text-gray-500 text-xl ml-1">.00</span>
            </div>
            <div class="flex items-center mt-5 text-green-500">
              <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-pulse"></span>
              <span class="text-[10px] font-bold uppercase tracking-wider">Secure Account</span>
            </div>
          </div>
          <button onclick="addMoney()" class="btn-add px-8">
            <i class="ph ph-plus-bold me-2"></i> Add Money
          </button>
        </div>

        <h3 class="text-lg font-bold mb-6">Transaction History</h3>

        <div class="glass-card overflow-hidden">
          <% if (wallet.transactions && wallet.transactions.length > 0) { %>
            <% wallet.transactions.sort((a, b) => new Date(b.date) - new Date(a.date)).forEach(tx => { %>
              <div class="flex items-center justify-between p-6 border-b border-gray-800/50 hover:bg-white/[0.02] transition">
                <div class="flex items-center gap-5">
                  <div class="w-12 h-12 rounded-2xl bg-gray-800/50 flex items-center justify-center <%= tx.transactionType === 'credit' ? 'text-green-400' : 'text-red-400' %>">
                    <% if (tx.source === 'order_cancel') { %>
                      <i class="ph ph-arrow-counter-clockwise text-xl"></i>
                    <% } else { %>
                      <i class="ph ph-receipt text-xl"></i>
                    <% } %>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-gray-100"><%= tx.description %></p>
                    <p class="text-[11px] text-gray-500 mt-1">
                      <%= new Date(tx.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %> 
                      • ID: <%= tx.orderId ? tx.orderId.toString().slice(-6).toUpperCase() : 'N/A' %>
                    </p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-sm font-bold <%= tx.transactionType === 'credit' ? 'text-green-400' : 'text-white' %>">
                    <%= tx.transactionType === 'credit' ? '+' : '-' %> ₹<%= tx.amount.toLocaleString('en-IN') %>
                  </p>
                  <p class="text-[9px] mt-1 font-bold uppercase tracking-widest <%= tx.status === 'success' ? 'text-gray-500' : 'text-red-500' %>">
                    <%= tx.status %>
                  </p>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <div class="p-20 text-center">
                <i class="ph ph-clock-counter-clockwise text-5xl text-gray-800 mb-4"></i>
                <p class="text-gray-600">No transactions recorded yet</p>
            </div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <script>
    // --- Razorpay Payment Logic ---
  async function addMoney() {
    const { value: amount } = await Swal.fire({
        title: 'Add Funds',
        input: 'number',
        inputLabel: 'Amound',
        inputPlaceholder: '₹ 500',
        background: '#111',
        color: '#fff',
        confirmButtonColor: '#5b42f3',
        showCancelButton: true,
        inputValidator: (value) => {
            if (!value || value <= 0) return 'pleas add amound';
        }
    });

    if (amount) {
        try {
            const response = await fetch('/add-money', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ amount: amount }) 
            });

            const order = await response.json();

            const options = {
                "key": "<%= razorpayKey %>", 
                "amount": order.amount, 
                "currency": "INR",
                "name": "Luxury Watches",
                "description": "Wallet Top-up",
                "order_id": order.id,
                "handler": async function (rzpRes) {
                    const verifyRes = await fetch('/verify-payment-add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ ...rzpRes })
                    });
                    const result = await verifyRes.json();
                    if (result.success) {
                        Swal.fire({ icon: 'success', title: 'Funds Added!', background: '#111', color: '#fff' })
                        .then(() => location.reload());
                    }
                },
                "prefill": { "name": "<%= user.fullname %>", "email": "<%= user.email %>"},
                "theme": { "color": "#5b42f3" }
            };

            const rzp = new window.Razorpay(options);
            rzp.open();
        } catch (err) {
            Swal.fire({ icon: 'error', title: 'Error', text: 'paymend faild', background: '#111', color: '#fff' });
        }
    }
}

    // --- Logout Handler ---
    function handleLogout() {
      Swal.fire({
        title: 'Logout?',
        text: "Are you sure you want to end your session?",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#5b42f3',
        cancelButtonColor: '#1a1a1a',
        confirmButtonText: 'Yes, Logout',
        background: '#111111',
        color: '#ffffff',
        iconColor: '#5b42f3'
      }).then((result) => {
        if (result.isConfirmed) document.getElementById('logout-form').submit();
      });
    }
  </script>
</body>

</html>