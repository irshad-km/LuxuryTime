<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>My Addresses | Luxury Watches</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --accent-purple: #5b42f3;
      --dark-surface: #111111;
      --border-color: #333333;
      --default-blue-glow: rgba(91, 66, 243, 0.15);
    }

    body {
      background-color: #070707;
      color: white;
      font-family: 'Inter', sans-serif;
      margin: 0;
    }

    /* Sidebar Navigation */
    .nav-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: 8px;
      color: #9ca3af;
      transition: all 0.3s ease;
      text-decoration: none;
    }

    .nav-item:hover {
      color: white;
      background: rgba(255, 255, 255, 0.05);
    }

    .nav-item.active {
      background: rgba(91, 66, 243, 0.1);
      color: var(--accent-purple);
      border: 1px solid rgba(91, 66, 243, 0.2);
    }

    /* Address Card */
    .address-card {
      background: var(--dark-surface);
      border-radius: 16px;
      padding: 24px;
      border: 1px solid var(--border-color);
      position: relative;
      height: 100%;
      transition: all 0.3s ease;
    }

    .address-card.is-default {
      border-color: var(--accent-purple);
      background: linear-gradient(145deg, #111111 0%, #161625 100%);
      box-shadow: 0 10px 30px var(--default-blue-glow);
    }

    .address-card h6 {
      font-weight: 700;
      font-size: 1.1rem;
      margin-bottom: 8px;
      color: white;
    }

    .address-card p {
      font-size: 14px;
      margin-bottom: 4px;
      color: #9ca3af;
    }

    .default-badge {
      position: absolute;
      top: 20px;
      right: 20px;
      background: var(--accent-purple);
      color: white;
      font-size: 10px;
      font-weight: 800;
      padding: 4px 12px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .btn-add {
      background: var(--accent-purple);
      color: #fff;
      border-radius: 10px;
      padding: 12px 24px;
      font-weight: 600;
      border: none;
      transition: 0.3s;
    }

    .btn-add:hover {
      opacity: 0.9;
      transform: translateY(-2px);
    }

    .action-btn {
      border: 1px solid var(--border-color);
      color: #9ca3af;
      font-size: 13px;
      border-radius: 8px;
      padding: 8px 14px;
      transition: 0.2s;
      background: transparent;
    }

    .action-btn:hover {
      background: rgba(255, 255, 255, 0.05);
      color: white;
      border-color: #666;
    }

    .delete-btn:hover {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border-color: #ef4444;
    }

    /* Modal Styling */
    .modal-content {
      background: #111;
      border: 1px solid var(--border-color);
      border-radius: 20px;
      color: white;
    }

    .form-control {
      background-color: #1f1f1f;
      border: 1px solid var(--border-color);
      color: white;
      padding: 12px;
      border: 1px solid #333;
    }

    .form-control:focus {
      background: #222;
      color: white;
      border-color: var(--accent-purple);
      box-shadow: none;
    }

    /* FIX: Placeholder Color to Solid White */
    .form-control::placeholder {
      color: #ffffff !important;
      opacity: 1 !important;
    }
    .form-control::-webkit-input-placeholder {
      color: #ffffff !important;
      opacity: 1 !important;
    }

    .btn-close {
      filter: invert(1);
    }

    /* Custom Toast Style */
    #customToast {
      position: fixed;
      top: 24px;
      right: 24px;
      background: #1a1a1a;
      border: 1px solid var(--accent-purple);
      padding: 16px 24px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      gap: 12px;
      z-index: 10000;
      transform: translateX(120%);
      transition: transform 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
      box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    #customToast.show { transform: translateX(0); }
  </style>
</head>

<body>

  <div id="customToast">
    <i class="ph-fill ph-check-circle text-2xl text-[var(--accent-purple)]"></i>
    <div>
      <p id="toastMessage" class="text-sm font-bold m-0"></p>
    </div>
  </div>

  <div class="modal fade" id="deleteConfirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
      <div class="modal-content text-center p-4">
        <div class="w-16 h-16 bg-red-500/10 text-red-500 rounded-full flex items-center justify-center mx-auto mb-4">
          <i class="ph ph-trash text-3xl"></i>
        </div>
        <h5 class="font-bold mb-2">Delete Address?</h5>
        <p class="text-gray-500 text-sm mb-6">This action cannot be undone.</p>
        <div class="flex gap-2">
          <button type="button" class="action-btn flex-1" data-bs-dismiss="modal">Cancel</button>
          <button type="button" id="confirmDeleteBtn" class="btn-add bg-red-600 flex-1 py-2">Delete</button>
        </div>
      </div>
    </div>
  </div>

  <div class="flex min-h-screen">
    <aside class="w-72 border-r border-gray-800 p-8 flex flex-col justify-between sticky top-0 h-screen bg-black">
      <div>
        <div class="flex items-center gap-2 mb-12">
          <i class="ph-bold ph-watch text-2xl text-[var(--accent-purple)]"></i>
          <span class="font-bold tracking-widest uppercase text-sm">Luxury Watches</span>
        </div>

        <div class="flex items-center gap-3 mb-10">
          <img src="<%= user.avatar %>" class="w-11 h-11 rounded-full border border-gray-700 object-cover">
          <div>
            <h3 class="text-sm font-bold truncate w-32"><%= user.name %></h3>
            <p class="text-[10px] text-gray-500 uppercase tracking-wider"><%= user.membership %></p>
          </div>
        </div>

        <nav class="space-y-2">
          <a href="/profile" class="nav-item"><i class="ph ph-user-circle text-xl"></i> My Profile</a>
          <a href="/orders" class="nav-item"><i class="ph ph-shopping-cart-simple text-xl"></i> My Orders</a>
          <a href="/wallet" class="nav-item"><i class="ph ph-wallet text-xl"></i> Wallet</a>
          <a href="/address" class="nav-item active"><i class="ph ph-map-pin text-xl"></i> Address</a>
        </nav>
      </div>
      <a href="/logout" class="flex items-center gap-2 text-gray-500 hover:text-red-400 transition text-sm font-medium">
        <i class="ph ph-sign-out text-xl"></i> Logout
      </a>
    </aside>

    <main class="flex-1 p-16">
      <div class="container-fluid">
        <div class="max-w-4xl mx-auto mb-6">
          <a href="/" class="text-xs text-gray-500 hover:text-[var(--accent-purple)] flex items-center gap-2 transition-colors">
            <i class="ph ph-arrow-left"></i> Back to Home
          </a>
        </div>

        <div class="d-flex justify-content-between align-items-center mb-12">
          <div>
            <h1 class="text-4xl font-bold mb-2">My Addresses</h1>
            <p class="text-gray-500">Manage your shipping and billing locations</p>
          </div>
          <button class="btn-add" data-bs-toggle="modal" data-bs-target="#addAddressModal">
            <i class="ph ph-plus-bold me-2"></i> Add Address
          </button>
        </div>

        <div class="row g-4">
          <% if (!addresses || addresses.length===0) { %>
            <div class="col-12 text-center py-20">
              <i class="ph ph-map-pin text-5xl text-gray-800 mb-4"></i>
              <p class="text-gray-600">No addresses added yet</p>
            </div>
          <% } %>

          <% addresses.forEach(address=> { %>
            <div class="col-xl-4 col-md-6">
              <div class="address-card <%= address.isDefault ? 'is-default' : '' %>">
                <% if(address.isDefault){ %><span class="default-badge">Default</span><% } %>
                <h6><%= address.fullname %></h6>
                <p><i class="ph ph-phone me-2"></i><%= address.phone %></p>
                <div class="mt-4">
                  <p><%= address.street %></p>
                  <p><%= address.city %>, <%= address.state %></p>
                  <p>Pincode: <%= address.pincode %></p>
                </div>
                <div class="flex gap-2 mt-6 pt-4 border-t border-gray-800">
                  <button class="action-btn flex-1" data-bs-toggle="modal" data-bs-target="#editModal<%= address._id %>">
                    <i class="ph ph-pencil-simple me-1"></i> Edit
                  </button>
                  <button type="button" class="action-btn delete-btn flex-1" onclick="showDeleteModal('<%= address._id %>')">
                    <i class="ph ph-trash me-1"></i> Delete
                  </button>
                  <form id="deleteForm<%= address._id %>" action="/address/delete/<%= address._id %>" method="POST" class="hidden"></form>
                </div>
              </div>
            </div>

            <div class="modal fade" id="editModal<%= address._id %>">
              <div class="modal-dialog modal-dialog-centered">
                <form action="/address/edit" method="POST" class="modal-content needs-validation" novalidate onsubmit="handleFormSubmit(event, 'Address Updated')">
                  <div class="modal-header border-0 p-4">
                    <h5 class="modal-title font-bold text-xl">Edit Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <div class="modal-body p-4 pt-0">
                    <input type="hidden" name="addressId" value="<%= address._id %>">
                    <input class="form-control mb-3" name="fullname" value="<%= address.fullname %>" placeholder="Full Name" required minlength="3">
                    <input class="form-control mb-3" name="phone" value="<%= address.phone %>" placeholder="Phone" required pattern="[0-9]{10}">
                    <input class="form-control mb-3" name="street" value="<%= address.street %>" placeholder="Street" required>
                    <div class="row g-2 mb-3">
                      <div class="col-6"><input class="form-control" name="city" value="<%= address.city %>" placeholder="City" required></div>
                      <div class="col-6"><input class="form-control" name="state" value="<%= address.state %>" placeholder="State" required></div>
                    </div>
                    <input class="form-control mb-3" name="pincode" value="<%= address.pincode %>" placeholder="Pincode" required pattern="[0-9]{6}">
                    <div class="form-check mt-3">
                      <input class="form-check-input" type="checkbox" name="isDefault" id="check<%= address._id %>" <%=address.isDefault ? "checked" : "" %>>
                      <label class="form-check-label text-gray-400" for="check<%= address._id %>">Set as Default Address</label>
                    </div>
                  </div>
                  <div class="modal-footer border-0 p-4">
                    <button type="submit" class="btn-add w-100">Update Changes</button>
                  </div>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </main>
  </div>

  <div class="modal fade" id="addAddressModal">
    <div class="modal-dialog modal-dialog-centered">
      <form action="/address/add" method="POST" class="modal-content needs-validation" novalidate onsubmit="handleFormSubmit(event, 'Address Added Successfully')">
        <div class="modal-header border-0 p-4">
          <h5 class="modal-title font-bold text-xl">New Address</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body p-4 pt-0">
          <input class="form-control mb-3" name="fullname" placeholder="Full Name" required minlength="3">
          <input class="form-control mb-3" name="phone" placeholder="Phone Number" required pattern="[0-9]{10}">
          <input class="form-control mb-3" name="street" placeholder="Street Address" required>
          <div class="row g-2 mb-3">
            <div class="col-6"><input class="form-control" name="city" placeholder="City" required></div>
            <div class="col-6"><input class="form-control" name="state" placeholder="State" required></div>
          </div>
          <input class="form-control mb-3" name="pincode" placeholder="Pincode" required pattern="[0-9]{6}">
          <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" name="isDefault" id="newDef">
            <label class="form-check-label text-gray-400" for="newDef">Set as default</label>
          </div>
        </div>
        <div class="modal-footer border-0 p-4">
          <button type="submit" class="btn-add w-100">Save Address</button>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  
  <script>
    let activeDeleteId = null;
    const deleteModal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));

    function showToast(msg) {
      const toast = document.getElementById('customToast');
      document.getElementById('toastMessage').innerText = msg;
      toast.classList.add('show');
      setTimeout(() => { toast.classList.remove('show'); }, 3000);
    }

    function handleFormSubmit(e, message) {
      const form = e.currentTarget;
      if (form.checkValidity()) {
        e.preventDefault();
        showToast(message);
        setTimeout(() => { form.submit(); }, 1000);
      }
    }

    function showDeleteModal(id) {
      activeDeleteId = id;
      deleteModal.show();
    }

    document.getElementById('confirmDeleteBtn').addEventListener('click', () => {
      if (activeDeleteId) {
        showToast('Deleting Address...');
        setTimeout(() => {
          document.getElementById(`deleteForm${activeDeleteId}`).submit();
        }, 800);
      }
    });

    (function () {
      'use strict'
      var forms = document.querySelectorAll('.needs-validation')
      Array.prototype.slice.call(forms).forEach(function (form) {
        form.addEventListener('submit', function (event) {
          if (!form.checkValidity()) {
            event.preventDefault()
            event.stopPropagation()
          }
          form.classList.add('was-validated')
        }, false)
      })
    })()
  </script>
</body>
</html>