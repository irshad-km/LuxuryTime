<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Your Selection | Luxury Time</title>

    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200;300;400;500;600;700;800&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d0d0d",
                        "surface-dark": "#141414",
                        "accent-blue": "#3b82f6"
                    },
                    fontFamily: { "display": ["Manrope", "sans-serif"] }
                },
            },
        }
    </script>

    <style>
        body {
            background-color: #0E0E0E;
            color: white;
            font-family: 'Manrope', sans-serif;
        }

        .glass-card {
            background: rgba(20, 20, 20, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 10px;
        }
    </style>
</head>

<body class="overflow-x-hidden custom-scrollbar">

      <%- include('../partials/user/header') %>

    <main class="mx-auto max-w-7xl px-6 py-12 lg:px-8 min-h-[70vh]">
        <header class="mb-10">
            <h1 class="text-4xl font-bold tracking-tight">Your Selection</h1>
            <p class="mt-2 text-gray-400">
                <%= (cart && cart.items.length > 0) ? cart.items.length + ' items in your cart' : 'Your cart is empty' %>
            </p>
        </header>

        <% if (cart && cart.items.length > 0) { %>
            <div class="grid grid-cols-1 gap-x-12 gap-y-10 lg:grid-cols-12">

                <section class="lg:col-span-8 space-y-6">
                    <% cart.items.forEach(item => { %>
                        <div class="glass-card flex flex-col sm:flex-row gap-6 p-6 rounded-2xl">
                            <div class="h-40 w-full sm:w-40 flex-none overflow-hidden rounded-xl bg-neutral-900">
                                <img src="<%= item.selectedVariant.images?.[0] || 'placeholder.png' %>"
                                    alt="<%= item.product.name %>" class="w-full h-full object-cover">
                            </div>

                            <div class="flex flex-1 flex-col justify-between">
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h3 class="text-xl font-bold"><%= item.product.name %></h3>
                                        <p class="text-sm text-gray-500 mt-1"><%= item.product.description %></p>
                                    </div>
                                    <p class="text-xl font-medium tracking-tight">₹ <%= item.price.toLocaleString() %></p>
                                </div>

                                <div class="mt-6 flex items-center justify-between">
                                    <div class="flex items-center gap-4 text-xs font-semibold uppercase tracking-wider text-gray-500">
                                        <button type="button" onclick="confirmDelete('<%= item.product._id %>', '<%= item.product.name %>')"
                                            class="flex items-center gap-1 hover:text-red-400 transition">
                                            <span class="material-symbols-outlined text-lg">delete</span> Remove
                                        </button>
                                        
                                        <button class="flex items-center gap-1 hover:text-white transition">
                                            <span class="material-symbols-outlined text-lg">favorite</span> Save for Wishlist
                                        </button>
                                    </div>

                                    <div class="flex items-center border border-white/10 rounded-lg overflow-hidden bg-black/20">
                                        <button class="px-3 py-1 hover:bg-white/5 border-r border-white/10 text-gray-400"
                                            onclick="updateQty('<%= item.product._id %>', -1)">-</button>
                                        <span class="px-4 py-1 text-sm font-bold"><%= item.quantity %></span>
                                        <button class="px-3 py-1 hover:bg-white/5 border-l border-white/10 text-gray-400"
                                            onclick="updateQty('<%= item.product._id %>', 1)">+</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </section>

                <aside class="lg:col-span-4">
                    <div class="glass-card rounded-2xl p-8 sticky top-32">
                        <h2 class="text-lg font-bold mb-6 tracking-wide uppercase">Order Summary</h2>
                        <div class="space-y-4 border-b border-white/5 pb-6">
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-400">Subtotal</span>
                                <span class="font-bold">₹ <%= cart.grandTotal.toLocaleString() %></span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-gray-400">Shipping</span>
                                <span class="text-green-500 font-medium">Complimentary</span>
                            </div>
                        </div>
                        <div class="py-6 flex justify-between items-center">
                            <span class="text-gray-400">Grand Total</span>
                            <span class="text-2xl font-bold">₹ <%= cart.grandTotal.toLocaleString() %></span>
                        </div>
                        <div class="space-y-3">
                            <a href="/checkout" class="w-full bg-blue-600 hover:bg-blue-700 py-4 rounded-xl font-bold text-sm transition flex items-center justify-center gap-2">
                                Proceed to Checkout <span class="material-symbols-outlined text-lg">arrow_forward</span>
                            </a>
                            <a href="/shop" class="w-full block text-center border border-white/10 hover:bg-white/5 py-4 rounded-xl font-bold text-sm transition">
                                Continue Shopping
                            </a>
                        </div>
                    </div>
                </aside>
            </div>
        <% } else { %>
            <div class="flex flex-col items-center justify-center py-20 glass-card rounded-3xl border-dashed border-white/10">
                <span class="material-symbols-outlined text-7xl text-gray-700 mb-4">shopping_bag</span>
                <h2 class="text-2xl font-bold">Your cart is empty</h2>
                <p class="text-gray-500 mt-2 mb-8 text-center">Looks like you haven't added any luxury timepieces to your collection yet.</p>
                <a href="/shop" class="bg-white text-black px-8 py-3 rounded-full font-bold uppercase text-xs tracking-widest hover:bg-gray-200 transition">
                    Start Shopping
                </a>
            </div>
        <% } %>
    </main>

    <div id="deleteModal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="toggleDeleteModal(false)"></div>
        
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-md bg-surface-dark border border-white/10 p-8 rounded-2xl shadow-2xl">
            <div class="text-center">
                <span class="material-symbols-outlined text-red-500 text-5xl mb-4">delete_forever</span>
                <h3 class="text-xl font-bold mb-2">Remove Item?</h3>
                <p id="deleteMessage" class="text-gray-400 text-sm mb-8">Are you sure you want to remove this timepiece from your selection?</p>
                
                <div class="flex flex-col sm:flex-row gap-3">
                    <button onclick="toggleDeleteModal(false)" 
                        class="flex-1 px-6 py-3 border border-white/10 rounded-xl text-sm font-semibold hover:bg-white/5 transition">
                        Cancel
                    </button>
                    
                    <form id="deleteForm" action="" method="POST" class="flex-1">
                        <button type="submit" 
                            class="w-full px-6 py-3 bg-red-600 rounded-xl text-sm font-semibold hover:bg-red-700 transition">
                            Yes, Remove
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <footer class="mt-20 border-t border-white/10 py-10 px-8">
        <div class="mx-auto max-w-7xl flex flex-col sm:flex-row justify-between items-center gap-6">
            <p class="text-xs text-gray-500">© 2026 Luxury Time. All rights reserved.</p>
            <div class="flex gap-8 text-xs text-gray-500 font-medium">
                <a href="#" class="hover:text-white">Privacy Policy</a>
                <a href="#" class="hover:text-white">Terms of Service</a>
            </div>
        </div>
    </footer>

    <script>
        // Modal Toggle Logic
        function toggleDeleteModal(show) {
            const modal = document.getElementById('deleteModal');
            if (show) {
                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden'; 
            } else {
                modal.classList.add('hidden');
                document.body.style.overflow = '';
            }
        }

        // Setup and show delete confirmation
        function confirmDelete(productId, productName) {
            const form = document.getElementById('deleteForm');
            const message = document.getElementById('deleteMessage');
            
            // Set the form action dynamically
            form.action = `/cart/remove/${productId}`;
            // Set the message text
            message.innerText = `Are you sure you want to remove "${productName}" from your cart?`;
            
            toggleDeleteModal(true);
        }

        function updateQty(productId, change) {
            console.log(`Update quantity for ${productId} by ${change}`);
            // Logic for fetch call to update quantity would go here
        }
    </script>

</body>
</html>