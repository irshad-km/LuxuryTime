<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luxury Time | Exclusive Collection</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&display=swap');

        :root {
            --bg-pure-black: #000000;
            --accent-blue: #0066ff;
            --ui-gray: #1a1a1a;
        }

        body {
            background-color: var(--bg-pure-black);
            color: #ffffff;
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* --- UPDATED SEARCH BAR (Minimalist Underline) --- */
        .search-wrapper {
            position: relative;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.4s ease;
        }

        .search-wrapper:focus-within {
            border-bottom: 1px solid var(--accent-blue);
        }

        /* --- PRODUCT GRID IMPROVEMENTS --- */
        .product-item {
            position: relative;
            transition: all 0.5s cubic-bezier(0.2, 1, 0.3, 1);
        }

        .product-image {
            transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), filter 0.5s ease;
            filter: brightness(0.8);
            width: 100%; /* Increased size */
            height: auto;
            object-fit: contain;
        }

        .product-item:hover .product-image {
            transform: scale(1.05);
            filter: brightness(1.1);
        }

        /* Sidebar UI */
        .sidebar-container {
            background: #0a0a0a;
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            min-height: 100vh;
        }

        ::-webkit-scrollbar { width: 3px; }
        ::-webkit-scrollbar-track { background: #000; }
        ::-webkit-scrollbar-thumb { background: #222; }
    </style>
</head>

<body class="antialiased">

    <%- include('../partials/user/header') %>

    <div class="flex flex-col lg:flex-row min-h-screen">

      <aside class="w-full lg:w-72 sidebar-container p-8 sticky top-0 h-screen overflow-y-auto">
            <div class="flex justify-between items-center mb-10">
                <h2 class="text-lg font-medium tracking-tight">Filters</h2>
                <button class="text-[10px] text-blue-500 uppercase tracking-widest font-bold">Reset</button>
            </div>

            <form action="/shop" method="GET" id="filterForm">
                
                <div class="mb-12">
                    <h4 class="filter-section-title">Category</h4>
                    <div class="space-y-4">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="category" value="all" checked>
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">All</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="category" value="men">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Men</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="category" value="women">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Women</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="category" value="unisex">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Unisex Watches</span>
                        </label>
                    </div>
                </div>

                <div class="mb-12">
                    <h4 class="filter-section-title">Price Range</h4>
                    <div class="space-y-4">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" name="price" value="under1000">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Below ₹1,000/-</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" name="price" value="1000-5000">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">₹1,000 - ₹5,000</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="checkbox" name="price" value="above5000">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Above ₹5,000</span>
                        </label>
                    </div>
                </div>

                <div class="mb-12">
                    <h4 class="filter-section-title">Sort By</h4>
                    <div class="space-y-4">
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="sort" value="priceLow">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Price: Low to High</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="sort" value="priceHigh">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">Price: High to Low</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group">
                            <input type="radio" name="sort" value="new">
                            <span class="text-sm text-neutral-400 group-hover:text-white transition">New Arrivals</span>
                        </label>
                    </div>
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-4 rounded-xl text-xs font-bold uppercase tracking-widest transition-all active:scale-95 shadow-lg shadow-blue-900/20">
                    Apply Filters
                </button>
            </form>
        </aside>

        <main class="flex-1 p-8 lg:p-16">
            
            <div class="max-w-xl mx-auto mb-24">
                <div class="search-wrapper flex items-center py-2">
                    <input type="text" placeholder="Search our collection..." 
                           class="bg-transparent w-full text-[10px] tracking-[0.3em] uppercase focus:outline-none placeholder:text-neutral-800">
                    <i class="fas fa-search text-[10px] text-neutral-700"></i>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-y-32 gap-x-16">
                <% products.forEach(product => { %>
                    <div class="product-item">
                        <a href="/product/<%= product._id %>" class="block group">
                            <div class="relative aspect-square flex items-center justify-center overflow-hidden mb-10">
                                <img src="<%= product.image %>" alt="<%= product.name %>"
                                     class="product-image">
                                
                                <% if(product.tag) { %>
                                    <span class="absolute top-0 left-0 text-[8px] tracking-[0.5em] uppercase text-blue-500 font-bold">
                                        // <%= product.tag %>
                                    </span>
                                <% } %>
                            </div>

                            <div class="text-center space-y-3">
                                <h3 class="text-[13px] font-light tracking-[0.3em] uppercase text-neutral-400 group-hover:text-white transition duration-500">
                                    <%= product.name %>
                                </h3>

                                <p class="text-[10px] text-neutral-700 tracking-[0.15em] uppercase leading-relaxed max-w-[280px] mx-auto">
                                    <%= product.description || 'Timeless Craftsmanship' %>
                                </p>

                                <div class="flex flex-col items-center pt-2">
                                    <span class="text-lg font-medium tracking-tighter text-white">
                                        ₹<%= product.price.toLocaleString() %>
                                    </span>
                                    <% if(product.oldPrice) { %>
                                        <span class="text-[11px] text-neutral-800 line-through tracking-tighter">
                                            ₹<%= product.oldPrice.toLocaleString() %>
                                        </span>
                                    <% } %>
                                </div>

                                <div class="w-4 h-[1px] bg-neutral-900 mx-auto group-hover:w-24 group-hover:bg-blue-600 transition-all duration-1000"></div>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>

            <div class="mt-40 flex justify-center items-center gap-12 border-t border-white/5 pt-20">
                <button class="text-[9px] uppercase tracking-[0.4em] text-neutral-700 hover:text-white transition">Prev</button>
                <div class="flex gap-4">
                    <span class="w-8 h-8 rounded-full border border-blue-600 flex items-center justify-center text-[10px] text-blue-500">01</span>
                </div>
                <button class="text-[9px] uppercase tracking-[0.4em] text-neutral-700 hover:text-white transition">Next</button>
            </div>
        </main>
    </div>

    <footer class="bg-black py-16 px-10 border-t border-white/5 text-center">
        <div class="text-[9px] tracking-[0.6em] text-neutral-800 uppercase">
            &copy; 2026 Luxury Time — Engineering Excellence.
        </div>
    </footer>

</body>
</html>