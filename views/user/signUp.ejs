<%- include('../partials/user/header') %>

  <div class="relative min-h-[calc(100vh-64px)] flex items-center justify-center px-4 py-6 bg-black overflow-hidden">

    <!-- Background -->
    <div class="absolute inset-0 z-0">
      <div class="w-full h-full bg-cover bg-center opacity-20" style="background-image: url('/images/back.png');"></div>
    </div>

    <div class="absolute inset-0 bg-black/60 z-0"></div>

    <!-- Card -->
    <div
      class="relative z-10 w-full max-w-[460px] bg-charcoal/80 backdrop-blur-2xl border border-white/5 rounded-2xl p-8 shadow-2xl">

      <!-- Title -->
      <header class="text-center mb-6">
        <h1 class="text-2xl font-bold text-white mb-1">Create Your Account</h1>
        <p class="text-slate-400 text-xs">Join us and find your perfect watch</p>
      </header>

      <!-- Google Signup -->
      <a href="/auth/google"
        class="flex items-center justify-center gap-3 w-full bg-white text-black text-sm font-semibold py-3 rounded-lg hover:bg-gray-100 transition">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-5 h-5">
        Sign up with Google
    </a>


      <!-- Divider -->
      <div class="flex items-center my-5">
        <div class="flex-grow h-px bg-white/10"></div>
        <span class="px-3 text-xs text-slate-400">or</span>
        <div class="flex-grow h-px bg-white/10"></div>
      </div>

      <!-- Signup Form -->
      <form id="signupForm" action="/signup" method="POST" class="space-y-4">

        
        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Full Name</label>
          <input id="fullname" name="fullname" type="text" placeholder="John Doe"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none">
          <p id="fullnameError" class="text-red-500 text-xs mt-1"></p>
        </div>

        
        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Email Address</label>
          <input id="email" name="email" type="email" placeholder="john@example.com"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none">
          <p id="emailError" class="text-red-500 text-xs mt-1"></p>
        </div>

        
        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Phone Number</label>
          <input id="phone" name="phone" type="tel" placeholder="9XXXXXXXXX"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none" maxlength="10">
          <p id="phoneError" class="text-red-500 text-xs mt-1"></p>
        </div>

       
        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Referral Code (optional)</label>
          <input id="referral" name="referral" type="text" placeholder="REF123"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none">
          <p id="referralError" class="text-red-500 text-xs mt-1"></p>
        </div>

        
        <div class="grid grid-cols-2 gap-3">
          <div>
            <input id="password" name="password" type="password" placeholder="Password"
              class="w-full bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none">
            <p id="passwordError" class="text-red-500 text-xs mt-1"></p>
          </div>

          <div>
            <input id="confirmPassword" name="confirmPassword" type="password" placeholder="Confirm"
              class="w-full bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none">
            <p id="confirmPasswordError" class="text-red-500 text-xs mt-1"></p>
          </div>
        </div>

        <!-- Submit -->
        <button class="w-full mt-2 rounded-lg px-3 py-3.5 text-sm font-bold text-white shadow-lg transition-all"
          style="background:#3e3efa;">
          Create Account →
        </button>

      </form>

      <!-- Footer -->
      <footer class="mt-6 text-center">
        <p class="text-xs text-slate-400">
          Already have an account?
          <a href="/login" class="text-primary font-semibold">Login</a>
        </p>
      </footer>

    </div>
  </div>

  <!-- Validation Script (same as yours, unchanged) -->
  <script>
    const form = document.getElementById("signupForm");
    const fullname = document.getElementById("fullname");
    const email = document.getElementById("email");
    const phone = document.getElementById("phone");
    const referral = document.getElementById("referral");
    const password = document.getElementById("password");
    const confirmPassword = document.getElementById("confirmPassword");

    const fullnameError = document.getElementById("fullnameError");
    const emailError = document.getElementById("emailError");
    const phoneError = document.getElementById("phoneError");
    const referralError = document.getElementById("referralError");
    const passwordError = document.getElementById("passwordError");
    const confirmPasswordError = document.getElementById("confirmPasswordError");

    form.addEventListener("submit", function (e) {
      let valid = true;

      fullnameError.textContent = "";
      emailError.textContent = "";
      phoneError.textContent = "";
      referralError.textContent = "";
      passwordError.textContent = "";
      confirmPasswordError.textContent = "";

      if (fullname.value.trim().length < 3 || /\d/.test(fullname.value)) {
        fullnameError.textContent = "Enter valid full name";
        valid = false;
      }

      if (!email.value.includes("@")) {
        emailError.textContent = "Invalid email";
        valid = false;
      }

      if (phone.value && !/^[6-9]\d{9}$/.test(phone.value)) {
        phoneError.textContent = "Invalid phone number";
        valid = false;
      }

      if (referral.value && !/^[A-Z0-9]{3,10}$/i.test(referral.value)) {
        referralError.textContent = "Invalid referral code";
        valid = false;
      }

      if (password.value.length < 6) {
        passwordError.textContent = "Minimum 6 characters";
        valid = false;
      }

      if (password.value !== confirmPassword.value) {
        confirmPasswordError.textContent = "Passwords do not match";
        valid = false;
      }

      if (!valid) e.preventDefault();
    });
  </script>