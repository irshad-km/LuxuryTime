<%- include('../partials/user/header') %>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

<div class="relative min-h-[calc(100vh-64px)] flex items-center justify-center px-4 py-10 bg-black overflow-hidden">

  <div class="absolute inset-0 z-0">
    <div class="w-full h-full bg-cover bg-center opacity-20" style="background-image: url('/images/back.png');"></div>
  </div>
  <div class="absolute inset-0 bg-black/60 z-0"></div>

  <div class="relative z-10 w-full max-w-[460px]">
    
    <div class="bg-charcoal/80 backdrop-blur-2xl border border-white/5 rounded-2xl p-8 shadow-2xl">
      <header class="text-center mb-6">
        <h1 class="text-2xl font-bold text-white mb-1">Create Your Account</h1>
        <p class="text-slate-400 text-xs">Join us and find your perfect watch</p>
      </header>

      <a href="/auth/google"
        class="flex items-center justify-center gap-3 w-full bg-white text-black text-sm font-semibold py-3 rounded-lg hover:bg-gray-100 transition">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" class="w-5 h-5">
        Sign up with Google
      </a>

      <% if(typeof message !== 'undefined' && message) { %>
        <div class="mt-4 flex items-center justify-center gap-2 bg-red-500/10 border border-red-500/20 py-2 px-3 rounded-lg">
          <i class="fas fa-circle-exclamation text-red-500 text-[10px]"></i>
          <p class="text-red-500 text-[11px] font-medium tracking-tight"><%= message %></p>
        </div>
      <% } %>

      <div class="flex items-center my-5">
        <div class="flex-grow h-px bg-white/10"></div>
        <span class="px-3 text-xs text-slate-400">or</span>
        <div class="flex-grow h-px bg-white/10"></div>
      </div>

      <form id="signupForm" action="/signup" method="POST" class="space-y-4" novalidate>

        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Full Name</label>
          <input id="fullname" name="fullname" type="text" placeholder="John Doe"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none border border-transparent focus:border-[#3e3efa] transition">
          <p id="fullnameError" class="text-red-500 text-[11px] mt-1 h-3"></p>
        </div>

        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Email Address</label>
          <input id="email" name="email" type="email" placeholder="john@example.com"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none border border-transparent focus:border-[#3e3efa] transition">
          <p id="emailError" class="text-red-500 text-[11px] mt-1 h-3"></p>
        </div>

        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Phone Number</label>
          <input id="phone" name="phone" type="tel" placeholder="9XXXXXXXXX"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none border border-transparent focus:border-[#3e3efa] transition"
            maxlength="10">
          <p id="phoneError" class="text-red-500 text-[11px] mt-1 h-3"></p>
        </div>

        <div>
          <label class="text-[10px] uppercase font-bold text-slate-500">Referral Code (optional)</label>
          <input id="referral" name="referral" type="text" placeholder="REF123"
            class="w-full mt-1 bg-white/5 rounded-lg px-4 py-3 text-sm text-white outline-none border border-transparent focus:border-[#3e3efa] transition">
          <p id="referralError" class="text-red-500 text-[11px] mt-1 h-3"></p>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="relative">
            <input id="password" name="password" type="password" placeholder="Password"
              class="w-full bg-white/5 rounded-lg px-4 py-3 pr-10 text-sm text-white outline-none border border-transparent focus:border-[#3e3efa] transition">
            <button type="button" onclick="toggleVisibility('password', this)" class="absolute right-3 top-3.5 text-slate-500 hover:text-white transition-colors">
              <i class="fas fa-eye text-xs"></i>
            </button>
            <p id="passwordError" class="text-red-500 text-[10px] mt-1 leading-tight h-6"></p>
          </div>

          <div class="relative">
            <input id="confirmPassword" name="confirmPassword" type="password" placeholder="Confirm"
              class="w-full bg-white/5 rounded-lg px-4 py-3 pr-10 text-sm text-white outline-none border border-transparent focus:border-[#3e3efa] transition">
            <button type="button" onclick="toggleVisibility('confirmPassword', this)" class="absolute right-3 top-3.5 text-slate-500 hover:text-white transition-colors">
              <i class="fas fa-eye text-xs"></i>
            </button>
            <p id="confirmPasswordError" class="text-red-500 text-[10px] mt-1 leading-tight h-6"></p>
          </div>
        </div>

        <button type="submit"
          class="w-full mt-2 rounded-lg px-3 py-3.5 text-sm font-bold text-white shadow-lg transition-all active:scale-95"
          style="background:#3e3efa;">
          Create Account →
        </button>

      </form>

      <footer class="mt-6 text-center">
        <p class="text-xs text-slate-400">
          Already have an account?
          <a href="/login" class="text-[#3e3efa] font-semibold">Login</a>
        </p>
      </footer>

    </div>
  </div>
</div>

<script>
  // Password Visibility Toggle Function
  function toggleVisibility(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === "password") {
      input.type = "text";
      icon.classList.replace('fa-eye', 'fa-eye-slash');
    } else {
      input.type = "password";
      icon.classList.replace('fa-eye-slash', 'fa-eye');
    }
  }

  const form = document.getElementById("signupForm");

  const inputs = {
    fullname: document.getElementById("fullname"),
    email: document.getElementById("email"),
    phone: document.getElementById("phone"),
    referral: document.getElementById("referral"),
    password: document.getElementById("password"),
    confirmPassword: document.getElementById("confirmPassword")
  };

  const errors = {
    fullname: document.getElementById("fullnameError"),
    email: document.getElementById("emailError"),
    phone: document.getElementById("phoneError"),
    referral: document.getElementById("referralError"),
    password: document.getElementById("passwordError"),
    confirmPassword: document.getElementById("confirmPasswordError")
  };

  const validateEmail = (email) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  const validatePhone = (phone) => /^[6-9]\d{9}$/.test(phone);
  
  const validateStrongPassword = (pass) => {
    return /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{6,}$/.test(pass);
  };

  function checkValidity() {
    let isValid = true;

    // Name
    if (inputs.fullname.value.trim().length < 3) {
      errors.fullname.textContent = "Name must be at least 3 characters";
      isValid = false;
    } else if (/[^a-zA-Z\s]/.test(inputs.fullname.value)) {
      errors.fullname.textContent = "Letters only";
      isValid = false;
    } else { errors.fullname.textContent = ""; }

    // Email
    if (!validateEmail(inputs.email.value)) {
      errors.email.textContent = "Invalid email address";
      isValid = false;
    } else { errors.email.textContent = ""; }

    // Phone
    if (!validatePhone(inputs.phone.value)) {
      errors.phone.textContent = "Valid 10-digit number required";
      isValid = false;
    } else { errors.phone.textContent = ""; }

    // Password
    const passVal = inputs.password.value;
    if (passVal.length < 6) {
      errors.password.textContent = "Min 6 characters required";
      isValid = false;
    } else if (!validateStrongPassword(passVal)) {
      errors.password.textContent = "Include Upper, Lower, Num & Special char";
      isValid = false;
    } else { errors.password.textContent = ""; }

    // Confirm Password
    if (inputs.confirmPassword.value === "") {
      errors.confirmPassword.textContent = "Please confirm password";
      isValid = false;
    } else if (inputs.confirmPassword.value !== inputs.password.value) {
      errors.confirmPassword.textContent = "Passwords do not match";
      isValid = false;
    } else { errors.confirmPassword.textContent = ""; }

    return isValid;
  }

  Object.values(inputs).forEach(input => {
    input.addEventListener("input", checkValidity);
  });

  form.addEventListener("submit", function (e) {
    if (!checkValidity()) {
      e.preventDefault();
    }
  });
</script>