<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luxury Time | Exclusive Collection</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@200;300;400;500;600&display=swap');

        :root {
            --bg-pure-black: #000;
            --accent-blue: #0066ff;
            --accent-red: #ff3b30;
        }

        body {
            background: var(--bg-pure-black);
            color: #fff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .search-wrapper {
            border-bottom: 1px solid rgba(255, 255, 255, .1);
            padding-bottom: 12px;
            transition: .4s;
        }

        .search-wrapper:focus-within {
            border-bottom-color: var(--accent-blue);
        }

        .sidebar-container {
            background: #0a0a0a;
            border-right: 1px solid rgba(255, 255, 255, .05);
        }

        .product-item {
            transition: .5s cubic-bezier(.2, 1, .3, 1);
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
        }

        .product-image {
            transition: transform .8s cubic-bezier(.16, 1, .3, 1), filter .4s;
            filter: brightness(.8);
            max-height: 100%;
            object-fit: contain;
        }

        .product-item:hover .product-image {
            transform: scale(1.05);
            filter: brightness(1.15);
        }

        .wishlist-btn {
            position: absolute;
            top: 10px;
            left: 20px;
            z-index: 30;
            background: rgba(0, 0, 0, 0.3);
            width: 35px;
            height: 35px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .wishlist-btn:hover { background: white; }
        .wishlist-btn:hover i { color: #ff3b30; }

        .btn-pill-blue {
            background: var(--accent-blue);
            color: white;
            padding: 8px 20px;
            border-radius: 9999px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-weight: 600;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .pg-active {
            background: var(--accent-blue);
            border-color: var(--accent-blue);
            color: white;
        }

        .loading-overlay {
            opacity: 0.5;
            pointer-events: none;
            filter: blur(2px);
        }

        ::-webkit-scrollbar { width: 3px; }
        ::-webkit-scrollbar-thumb { background: #222; }
    </style>
</head>

<body class="antialiased">

    <%- include('../partials/user/header') %>

    <% 
        const cat = category || 'all'; 
        const s = sort || ''; 
        const priceArr = Array.isArray(price) ? price : (price ? [price] : []); 
        const currPage = parseInt(currentPage) || 1; 
        const totalPgs = parseInt(totalPages) || 1; 
        
        function buildQuery(newPage) { 
            let q = `/shop?page=${newPage}&category=${cat}&sort=${s}&search=${encodeURIComponent(search || '')}`; 
            priceArr.forEach(p => q += `&price=${p}`);
            return q;
        }

        function buildClearSearchQuery() {
            let q = `/shop?page=1&category=${cat}&sort=${s}&search=`;
            priceArr.forEach(p => q += `&price=${p}`);
            return q;
        }
    %>

    <div class="flex flex-col lg:flex-row min-h-screen">
        <aside class="w-full lg:w-72 sidebar-container p-8 sticky top-0 h-screen overflow-y-auto">
            <form id="filter-form" action="/shop" method="GET">
                <input type="hidden" name="search" id="hidden-search-input" value="<%= search || '' %>">

                <div class="flex justify-between items-center mb-10">
                    <h2 class="text-lg tracking-tight">Filters</h2>
                    <a href="/shop" class="text-[10px] text-blue-500 uppercase tracking-widest font-bold">Reset</a>
                </div>

                <div class="mb-12">
                    <h4 class="mb-6 text-xs tracking-[0.4em] uppercase text-neutral-500">Category</h4>
                    <label class="flex gap-3 mb-4 cursor-pointer group">
                        <input type="radio" name="category" value="all" <%= cat==='all' ? 'checked' : '' %>>
                        <span class="text-sm text-neutral-400 group-hover:text-white transition">ALL</span>
                    </label>
                    <% if(categories && categories.length > 0) { %>
                        <% categories.forEach(c => { %>
                            <label class="flex gap-3 mb-4 cursor-pointer group">
                                <input type="radio" name="category" value="<%= c.name %>" <%= cat===c.name ? 'checked' : '' %>>
                                <span class="text-sm text-neutral-400 group-hover:text-white transition"><%= c.name.toUpperCase() %></span>
                            </label>
                        <% }) %>
                    <% } %>
                </div>

                <div class="mb-12">
                    <h4 class="mb-6 text-xs tracking-[0.4em] uppercase text-neutral-500">Price Range</h4>
                    <% ['under1000', '1000-5000', 'above5000'].forEach(pRange => { %>
                        <label class="flex gap-3 mb-4 cursor-pointer">
                            <input type="checkbox" name="price" value="<%= pRange %>" <%= priceArr.includes(pRange) ? 'checked' : '' %>>
                            <span class="text-sm text-neutral-400">
                                <%= pRange === 'under1000' ? 'Below ₹1,000' : pRange === '1000-5000' ? '₹1,000 – ₹5,000' : 'Above ₹5,000' %>
                            </span>
                        </label>
                    <% }) %>
                </div>

                <div class="mb-12">
                    <h4 class="mb-6 text-xs tracking-[0.4em] uppercase text-neutral-500">Sort By</h4>
                    <% const sorts = { priceLow: 'Price: Low → High', priceHigh: 'Price: High → Low', new: 'New Arrivals' } %>
                    <% Object.keys(sorts).forEach(key => { %>
                        <label class="flex gap-3 mb-4 cursor-pointer">
                            <input type="radio" name="sort" value="<%= key %>" <%= s===key ? 'checked' : '' %>>
                            <span class="text-sm text-neutral-400"><%= sorts[key] %></span>
                        </label>
                    <% }) %>
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 py-4 rounded-xl text-xs uppercase tracking-widest transition-all duration-300">
                    Apply Filters
                </button>
            </form>
        </aside>

        <main class="flex-1 p-8 lg:p-16 flex flex-col items-center">
            <form id="search-form" action="/shop" method="GET" class="max-w-2xl w-full mb-24">
                <input type="hidden" name="category" value="<%= cat %>">
                <input type="hidden" name="sort" value="<%= s %>">
                <% priceArr.forEach(p => { %><input type="hidden" name="price" value="<%= p %>"><% }) %>

                <div class="search-wrapper flex items-center gap-6">
                    <input type="text" name="search" id="search-input" value="<%= search || '' %>"
                        placeholder="Search our collection..."
                        class="bg-transparent flex-1 text-[12px] tracking-[0.2em] uppercase focus:outline-none placeholder:text-neutral-800">

                    <div id="search-actions" class="flex items-center gap-3">
                        <button type="submit" class="btn-pill-blue">
                            <i class="fas fa-search"></i> Search
                        </button>
                        <div id="clear-btn-container">
                            <% if(search && search.length > 0) { %>
                                <a href="<%= buildClearSearchQuery() %>" id="clear-search" class="px-4 py-2 bg-red-600/20 text-red-500 rounded-full text-[10px] uppercase font-bold tracking-widest">
                                    Clear
                                </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </form>

            <div id="product-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-y-32 gap-x-12 w-full flex-grow transition-all duration-500">
                <% if(!products || products.length === 0){ %>
                    <div class="col-span-full text-center py-20">
                        <p class="text-neutral-600 uppercase tracking-[0.4em] text-[10px]">No results discovered</p>
                    </div>
                <% } else { %>
                    <% products.forEach(product => { %>
                        <% 
                            const hasVariant = product.variants && product.variants.length > 0;
                            const currentVariantId = hasVariant ? product.variants[0]._id : ''; 
                            const currentColor = hasVariant ? product.variants[0].color : "Default";
                        %>
                        <div class="product-item">
                            <button onclick="addToWishlist({
                                productId: '<%= product._id %>',
                                variantId: '<%= currentVariantId %>', 
                                name: '<%= product.name.replace(/'/g, "\\'") %>',
                                image: '<%= product.image %>',
                                price: '<%= product.salePrice %>',
                                color: '<%= currentColor %>'
                            }, this)" class="wishlist-btn">
                                <i class="far fa-heart text-neutral-400 text-xs"></i>
                            </button>

                            <a href="/product/<%= product._id %>" class="block group w-full relative">
                                <% if (product.offerPercentage > 0) { %>
                                    <span class="absolute top-0 right-4 bg-blue-600 text-[9px] font-bold px-2 py-1 rounded-full z-10 shadow-lg">
                                        <%= product.offerPercentage %>% OFF
                                    </span>
                                <% } %>
                                <div class="aspect-square flex items-center justify-center mb-10 overflow-hidden px-4">
                                    <img src="<%= product.image %>" class="product-image w-full h-full" alt="<%= product.name %>">
                                </div>
                                <div class="text-center space-y-4 px-2">
                                    <h3 class="text-[12px] tracking-[0.3em] uppercase text-neutral-400 group-hover:text-white transition-colors duration-500"><%= product.name %></h3>
                                    <div class="pt-2 flex flex-col items-center">
                                        <span class="text-base font-semibold tracking-wide text-white">₹<%= (product.salePrice).toLocaleString() %></span>
                                        <% if (product.offerPercentage > 0) { %>
                                            <span class="text-[11px] text-neutral-600 line-through">₹<%= (product.regularPrice).toLocaleString() %></span>
                                        <% } %>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% }) %>
                <% } %>
            </div>

            <div id="pagination-container" class="w-full">
                <% if(totalPgs > 1) { %>
                    <div class="mt-40 mb-10 flex justify-center items-center gap-2">
                        <a href="<%= currPage > 1 ? buildQuery(currPage - 1) : '#' %>" class="pg-btn w-12 h-12 flex items-center justify-center rounded-full <%= currPage === 1 ? 'opacity-20 pointer-events-none' : '' %>"><i class="fas fa-chevron-left text-[10px]"></i></a>
                        <div class="flex gap-2 mx-4">
                            <% for(let i = 1; i <= totalPgs; i++) { %>
                                <a href="<%= buildQuery(i) %>" class="pg-btn w-11 h-11 flex items-center justify-center rounded-full text-[10px] <%= currPage === i ? 'pg-active' : '' %>"><%= i < 10 ? '0' + i : i %></a>
                            <% } %>
                        </div>
                        <a href="<%= currPage < totalPgs ? buildQuery(currPage + 1) : '#' %>" class="pg-btn w-12 h-12 flex items-center justify-center rounded-full <%= currPage === totalPgs ? 'opacity-20 pointer-events-none' : '' %>"><i class="fas fa-chevron-right text-[10px]"></i></a>
                    </div>
                <% } %>
            </div>
        </main>
    </div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const productGrid = document.getElementById('product-grid');
        const paginationContainer = document.getElementById('pagination-container');
        const clearBtnContainer = document.getElementById('clear-btn-container');
        const searchInput = document.getElementById('search-input');
        const hiddenSearch = document.getElementById('hidden-search-input');

        async function updateShopContent(url) {
            try {
                productGrid.classList.add('loading-overlay');
                const response = await fetch(url);
                const html = await response.text();
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                // Update Grid and Pagination
                productGrid.innerHTML = doc.getElementById('product-grid').innerHTML;
                paginationContainer.innerHTML = doc.getElementById('pagination-container').innerHTML;
                
                // CRITICAL: Update the Clear Button Container
                clearBtnContainer.innerHTML = doc.getElementById('clear-btn-container').innerHTML;
                
                // Sync the search input values
                const newSearchVal = new URL(url, window.location.origin).searchParams.get('search') || '';
                searchInput.value = newSearchVal;
                hiddenSearch.value = newSearchVal;

                window.history.pushState({}, '', url);
                productGrid.classList.remove('loading-overlay');
                window.scrollTo({ top: 0, behavior: 'smooth' });
            } catch (error) {
                console.error('Fetch error:', error);
                productGrid.classList.remove('loading-overlay');
            }
        }

        // Search Form Submit
        document.getElementById('search-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            updateShopContent(`/shop?${new URLSearchParams(formData).toString()}`);
        });

        // Filter Form Submit
        document.getElementById('filter-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            updateShopContent(`/shop?${new URLSearchParams(formData).toString()}`);
        });

        // Global Click Listener for AJAX elements
        document.addEventListener('click', (e) => {
            const pgBtn = e.target.closest('.pg-btn');
            const clearBtn = e.target.closest('#clear-search');
            
            if (pgBtn) {
                e.preventDefault();
                updateShopContent(pgBtn.getAttribute('href'));
            }
            if (clearBtn) {
                e.preventDefault();
                updateShopContent(clearBtn.getAttribute('href'));
            }
        });
    });

    async function addToWishlist(pData, btnElement) {
        try {
            const response = await fetch('/wishlist/add', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ...pData, dotColor: pData.color, material: 'Premium', size: 'Standard' })
            });
            const data = await response.json();
            if (response.status === 401) {
                Swal.fire({ icon: 'warning', title: 'Login Required', background: '#111', color: '#fff' }).then(() => window.location.href = '/login');
                return;
            }
            if (response.ok) {
                const heart = btnElement.querySelector('i');
                heart.classList.replace('far', 'fas');
                heart.classList.add('text-red-500');
                Swal.fire({ toast: true, position: 'top-end', icon: 'success', title: 'Added', showConfirmButton: false, timer: 1500, background: '#111', color: '#fff' });
            }
        } catch (e) { console.error(e); }
    }
</script>
</body>
</html>