<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Luxury Time | Premium Collection</title>

    <link rel="icon" href="https://fonts.gstatic.com/s/i/short-term/release/materialsymbolsoutlined/watch/default/48px.svg">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#0d0d0d",
                        "accent": "#C0C0C0",
                        "background-dark": "#0E0E0E",
                        "surface-dark": "#141414",
                    },
                    fontFamily: { "display": ["Manrope", "sans-serif"] }
                },
            },
        }
    </script>

    <style>
        html { scroll-behavior: smooth; }
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0E0E0E; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #555; }
        
        /* Transition for Heart Icon */
        .material-symbols-outlined {
            transition: color 0.3s ease, font-variation-settings 0.3s ease;
        }

        .badge-shadow { box-shadow: 0 0 10px rgba(59, 130, 246, 0.5); }
    </style>
</head>

<body class="bg-background-dark text-white font-display overflow-x-hidden">
    <header class="sticky top-0 z-50 w-full border-b border-white/10 bg-background-dark/80 backdrop-blur-md">
        <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6 lg:px-8">

            <a href="/">
                <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-white text-3xl">watch</span>
                    <h1 class="text-xl font-bold tracking-[0.1em]">LUXURY TIME</h1>
                </div>
            </a>

            <nav class="hidden md:flex items-center gap-10">
                <a href="/" class="text-sm font-medium uppercase tracking-widest text-white">Home</a>
                <a href="/shop" class="text-sm font-medium uppercase tracking-widest text-gray-300 hover:text-white transition-colors">Shop</a>
                <a href="/about" class="text-sm font-medium uppercase tracking-widest text-gray-300 hover:text-white transition-colors">About</a>
            </nav>

            <div class="flex items-center gap-6">
                <% if (user) { %>
                    
                    <a href="/wishlist" class="relative text-gray-300 hover:text-white transition-colors group">
                        <span id="wishlist-icon" 
                              class="material-symbols-outlined text-[24px] 
                              <%= (typeof wishlistCount !== 'undefined' && wishlistCount > 0) ? 'text-red-500' : '' %>"
                              style="<%= (typeof wishlistCount !== 'undefined' && wishlistCount > 0) ? "font-variation-settings: 'FILL' 1;" : "font-variation-settings: 'FILL' 0;" %>">
                            favorite
                        </span>
                        
                        <div id="wishlist-badge-container">
                            <% if (typeof wishlistCount !== 'undefined' && wishlistCount > 0) { %>
                                <span id="wishlist-count"
                                    class="absolute -top-1.5 -right-1.5 flex h-4 w-4 min-w-[18px] items-center justify-center rounded-full bg-blue-600 px-1 text-[10px] font-bold text-white badge-shadow">
                                    <%= wishlistCount %>
                                </span>
                            <% } %>
                        </div>
                    </a>

                    <a href="/cart" class="relative text-gray-300 hover:text-white transition-colors">
                        <span class="material-symbols-outlined text-[26px]">shopping_bag</span>
                        <div id="cart-badge-container">
                            <% if (typeof totalQty !== 'undefined' && totalQty > 0) { %>
                                <span id="cart-count"
                                    class="absolute -top-1.5 -right-1.5 flex h-4 w-4 min-w-[18px] items-center justify-center rounded-full bg-blue-600 px-1 text-[10px] font-bold text-white badge-shadow">
                                    <%= totalQty %>
                                </span>
                            <% } %>
                        </div>
                    </a>

                    <div class="relative group">
                        <button class="flex items-center gap-2 text-sm font-semibold uppercase tracking-wider">
                            <span class="material-symbols-outlined text-2xl">account_circle</span>
                            <span><%= user.fullname %></span>
                        </button>
                        <div class="absolute right-0 mt-3 w-44 rounded-lg bg-surface-dark border border-white/10 shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                            <a href="/profile" class="block px-4 py-3 text-sm hover:bg-white/5 transition border-b border-white/5">My Profile</a>
                            <a href="/orders" class="block px-4 py-3 text-sm hover:bg-white/5 transition border-b border-white/5">My Orders</a>
                            <button type="button" onclick="toggleLogoutModal(true)" class="w-full text-left px-4 py-3 text-sm text-red-400 hover:bg-red-500 hover:text-white transition rounded-b-lg">Logout</button>
                        </div>
                    </div>

                <% } else { %>
                    <div class="flex items-center gap-3">
                        <a href="/login">
                            <button class="border border-white/20 px-5 py-2 text-[10px] font-bold uppercase rounded-full hover:bg-white hover:text-black transition-all">Login</button>
                        </a>
                        <a href="/signUp">
                            <button class="bg-white px-5 py-2 text-[10px] font-bold uppercase text-black rounded-full hover:bg-gray-200 transition-all shadow-lg shadow-white/5">Sign Up</button>
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </header>

    <div id="logoutModal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" onclick="toggleLogoutModal(false)"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[90%] max-w-sm bg-surface-dark border border-white/10 p-8 rounded-2xl shadow-2xl">
            <div class="text-center">
                <div class="w-16 h-16 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="material-symbols-outlined text-red-500 text-3xl">logout</span>
                </div>
                <h3 class="text-xl font-bold mb-2">Confirm Logout</h3>
                <p class="text-gray-400 text-sm mb-8">Are you sure you want to log out from Luxury Time?</p>
                <div class="flex gap-3">
                    <button onclick="toggleLogoutModal(false)" class="flex-1 px-6 py-3 border border-white/10 rounded-xl text-sm font-semibold hover:bg-white/5 transition">Cancel</button>
                    <form action="/logout" method="POST" class="flex-1">
                        <button type="submit" class="w-full px-6 py-3 bg-red-600 rounded-xl text-sm font-semibold hover:bg-red-700 transition">Logout</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleLogoutModal(show) {
            const modal = document.getElementById('logoutModal');
            if (show) { 
                modal.classList.remove('hidden'); 
                document.body.style.overflow = 'hidden'; 
            } else { 
                modal.classList.add('hidden'); 
                document.body.style.overflow = ''; 
            }
        }
    </script>
</body>
</html>