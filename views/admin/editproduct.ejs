<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Edit Product</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');

        :root {
            --bg-main: #050505;
            --card-bg: #111111;
            --input-bg: #1a1a1a;
            --border-subtle: #262626;
            --accent-blue: #2563eb;
        }

        body {
            background-color: var(--bg-main);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex-grow: 1;
            padding: 3rem;
            width: calc(100% - 260px);
        }

        .glass-card {
            background: var(--card-bg);
            border: 1px solid var(--border-subtle);
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 2rem;
            position: relative;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #a1a1aa;
            margin-bottom: 8px;
            display: block;
        }

        .input-field {
            background: var(--input-bg);
            border: 1px solid var(--border-subtle);
            color: white;
            border-radius: 8px;
            padding: 12px 16px;
            width: 100%;
            outline: none;
        }

        .image-container {
            position: relative;
            width: 100%;
        }

        .image-upload-box {
            border: 2px dashed var(--border-subtle);
            border-radius: 12px;
            height: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
            overflow: hidden;
            background: #0d0d0d;
        }

        .image-upload-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        #successModal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }

        .success-card {
            background: #111;
            padding: 40px;
            border-radius: 24px;
            text-align: center;
            border: 1px solid #222;
            transform: scale(0.9);
            animation: popIn 0.3s forwards;
        }

        @keyframes popIn {
            to { transform: scale(1); }
        }

        #cropperModal {
            background: rgba(0, 0, 0, 0.9);
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

        .modal-content-wrapper {
            background: #111;
            padding: 24px;
            border-radius: 20px;
            width: 90%;
            max-width: 600px;
        }

        .remove-img-btn {
            position: absolute;
            top: -8px;
            right: -8px;
            background: #ef4444;
            color: white;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            z-index: 20;
            cursor: pointer;
            border: 2px solid var(--card-bg);
        }

        .cropper-container-box {
            width: 100%;
            height: 400px;
            background: #000;
            border-radius: 12px;
            overflow: hidden;
            margin-bottom: 20px;
        }
    </style>
</head>

<body>

    <div id="successModal">
        <div class="success-card">
            <div class="w-20 h-20 bg-blue-500/10 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-arrows-rotate text-4xl"></i>
            </div>
            <h2 class="text-2xl font-bold mb-2">Product Updated!</h2>
            <p class="text-zinc-400 mb-8">Changes have been saved successfully.</p>
            <div class="flex gap-3 justify-center">
                <span class="text-sm text-zinc-500 italic">Updating database...</span>
            </div>
        </div>
    </div>

    <div id="toastContainer" class="fixed top-6 right-6 z-[9999] flex flex-col gap-4">
        <% if (locals.error) { %>
            <div class="bg-red-600 text-white px-6 py-4 rounded-xl shadow-xl flex gap-4">
                <i class="fas fa-circle-exclamation text-xl"></i>
                <div class="flex-1">
                    <p class="font-semibold">Error</p>
                    <p class="text-sm"><%= error %></p>
                </div>
                <button onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
            </div>
        <% } %>
    </div>

    <div class="admin-wrapper">
        <%- include('../partials/admin/sidebar') %>

        <main class="main-content max-w-5xl mx-auto">
            <h1 class="text-3xl font-bold mb-8">Edit Product</h1>

            <form action="/admin/products/edit/<%= product._id %>" method="POST" enctype="multipart/form-data" id="productForm">

                <div class="glass-card">
                    <label class="form-label">Product Name</label>
                    <input type="text" name="name" id="productName" class="input-field" value="<%= product.name %>">

                    <label class="form-label mt-6">Description</label>
                    <textarea name="description" id="productDescription" rows="4" class="input-field"><%= product.description %></textarea>

                    <label class="form-label mt-6">Category</label>
                    <select name="category" class="input-field">
                        <% categories.forEach(cat=> { %>
                            <option value="<%= cat._id %>" <%=product.category.toString()===cat._id.toString() ? 'selected' : '' %>>
                                <%= cat.name %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div id="variantsSection">
                    <% product.variants.forEach((variant, vIndex)=> { %>
                        <div class="glass-card variant-card relative">
                            <label class="form-label">Color</label>
                            <select name="variants[<%= vIndex %>][color]" class="input-field" required>
                                <option value="Black" <%=variant.color==='Black' ? 'selected' : '' %>>Black</option>
                                <option value="White" <%=variant.color==='White' ? 'selected' : '' %>>White</option>
                                <option value="Red" <%=variant.color==='Red' ? 'selected' : '' %>>Red</option>
                                <option value="Blue" <%=variant.color==='Blue' ? 'selected' : '' %>>Blue</option>
                                <option value="Silver" <%=variant.color==='Silver' ? 'selected' : '' %>>Silver</option>
                                <option value="Green" <%=variant.color==='Green' ? 'selected' : '' %>>Green</option>
                            </select>

                            <div class="grid grid-cols-2 gap-4 mt-6">
                                <div>
                                    <label class="form-label">Regular Price</label>
                                    <input type="number" name="variants[<%= vIndex %>][regularPrice]" value="<%= variant.regularPrice %>" class="input-field reg-price" step="0.01">
                                </div>
                                <div>
                                    <label class="form-label">Sale Price</label>
                                    <input type="number" name="variants[<%= vIndex %>][salePrice]" value="<%= variant.salePrice %>" class="input-field sale-price" step="0.01">
                                </div>
                            </div>

                            <label class="form-label mt-6">Stock Quantity</label>
                            <input type="number" name="variants[<%= vIndex %>][quantity]" value="<%= variant.quantity %>" class="input-field qty-field">

                            <div class="grid grid-cols-4 gap-4 mt-6">
                                <% for(let i=0; i < 4; i++) { %>
                                    <div class="image-container" id="container-v<%= vIndex %>-input-<%= i %>">
                                        <button type="button" class="remove-img-btn <%= (variant.images && variant.images[i]) ? '' : 'hidden' %>" onclick="removeImage('v<%= vIndex %>-input-<%= i %>')">
                                            <i class="fas fa-times"></i>
                                        </button>
                                        <div class="image-upload-box" onclick="document.getElementById('v<%= vIndex %>-input-<%= i %>').click()">
                                            <% if (variant.images && variant.images[i]) { %>
                                                <img src="<%= variant.images[i] %>" id="img-v<%= vIndex %>-input-<%= i %>">
                                                <input type="hidden" name="variants[<%= vIndex %>][existingImages][<%= i %>]" value="<%= variant.images[i] %>" id="existing-v<%= vIndex %>-input-<%= i %>">
                                            <% } else { %>
                                                <i class="fas fa-image text-neutral-600 text-xl" id="icon-v<%= vIndex %>-input-<%= i %>"></i>
                                                <img src="" id="img-v<%= vIndex %>-input-<%= i %>" class="hidden">
                                            <% } %>
                                            <input type="file" id="v<%= vIndex %>-input-<%= i %>" name="variants[<%= vIndex %>][images]" class="hidden img-input" accept="image/*" onchange="initCropper(event, 'v<%= vIndex %>-input-<%= i %>')">
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <button type="button" onclick="addNewVariant()" class="w-full mb-8 py-3 border-2 border-dashed border-zinc-800 rounded-xl text-zinc-500 hover:text-white transition-all">
                    <i class="fas fa-plus mr-2"></i> Add New Color Variant
                </button>

                <div class="flex items-center justify-end gap-4 pb-10">
                    <a href="/admin/products" class="bg-zinc-800 hover:bg-zinc-700 text-white px-8 py-3 rounded-xl font-bold">Cancel</a>
                    <button type="submit" id="submitBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-10 py-3 rounded-xl font-bold transition-all">
                        Update Product
                    </button>
                </div>
            </form>
        </main>
    </div>

    <div id="cropperModal">
        <div class="modal-content-wrapper">
            <h3 class="text-xl font-bold mb-4 text-white">Crop Image</h3>
            <div class="cropper-container-box"><img id="cropperImage" src=""></div>
            <div class="flex justify-end gap-4">
                <button type="button" onclick="closeModal()" class="px-6 py-2 text-zinc-400">Cancel</button>
                <button type="button" onclick="cropImage()" class="px-8 py-2 bg-blue-600 text-white rounded-lg font-bold">Save Crop</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <script>
        let cropper;
        let currentInputId;
        let variantCount = <%= product.variants.length %>;

        function showToast(msg) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = "bg-red-600 text-white px-6 py-4 rounded-xl shadow-xl flex gap-4 mb-4";
            toast.innerHTML = `
                <i class="fas fa-circle-exclamation text-xl"></i>
                <div class="flex-1">
                    <p class="font-semibold">Validation Error</p>
                    <p class="text-sm">${msg}</p>
                </div>
                <button onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>`;
            container.appendChild(toast);
            setTimeout(() => { if (toast) toast.remove(); }, 5000);
        }

        // --- UPDATED SUBMIT HANDLER WITH VALIDATION ---
        document.getElementById("productForm").addEventListener("submit", function (e) {
            e.preventDefault();

            const name = document.getElementById('productName').value.trim();
            const description = document.getElementById('productDescription').value.trim();
            const variants = document.querySelectorAll('.variant-card');

            if (name === "") return showToast("Product name is required.");
            if (description.length < 10) return showToast("Description should be at least 10 characters.");

            for (let variant of variants) {
                const regPrice = variant.querySelector('.reg-price').value;
                const salePrice = variant.querySelector('.sale-price').value;
                const qty = variant.querySelector('.qty-field').value;

                // Regular Price Validation (> 0)
                if (!regPrice || parseFloat(regPrice) <= 0) {
                    return showToast("Regular price must be greater than 0.");
                }

                // Quantity Validation (> 0)
                if (qty === "" || parseInt(qty) <= 0) {
                    return showToast("Stock quantity must be greater than 0.");
                }

                // Sale Price Validation (If entered, must be > 0 and < Regular Price)
                if (salePrice !== "") {
                    const sPrice = parseFloat(salePrice);
                    const rPrice = parseFloat(regPrice);

                    if (sPrice <= 0) {
                        return showToast("Sale price must be greater than 0.");
                    }
                    if (sPrice >= rPrice) {
                        return showToast("Sale price must be lower than Regular price.");
                    }
                }
            }

            const btn = document.getElementById('submitBtn');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Updating...';
            btn.disabled = true;

            document.getElementById('successModal').style.display = 'flex';

            setTimeout(() => {
                this.submit();
            }, 1800);
        });

        function initCropper(event, id) {
            const input = event.target;
            if (input.files && input.files[0]) {
                currentInputId = id;
                const reader = new FileReader();
                reader.onload = (e) => {
                    const modal = document.getElementById('cropperModal');
                    const image = document.getElementById('cropperImage');
                    image.src = e.target.result;
                    modal.style.display = 'flex';
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(image, { aspectRatio: 1, viewMode: 1 });
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        function closeModal() {
            document.getElementById('cropperModal').style.display = 'none';
            if (cropper) cropper.destroy();
        }

        function cropImage() {
            const canvas = cropper.getCroppedCanvas({ width: 600, height: 600 });
            const input = document.getElementById(currentInputId);
            const imgElement = document.getElementById('img-' + currentInputId);
            const iconElement = document.getElementById('icon-' + currentInputId);
            const container = document.getElementById('container-' + currentInputId);
            const removeBtn = container.querySelector('.remove-img-btn');

            canvas.toBlob((blob) => {
                const file = new File([blob], `img-${Date.now()}.jpg`, { type: "image/jpeg" });
                const dt = new DataTransfer();
                dt.items.add(file);
                input.files = dt.files;
                imgElement.src = canvas.toDataURL('image/jpeg');
                imgElement.classList.remove('hidden');
                if (iconElement) iconElement.classList.add('hidden');
                removeBtn.classList.remove('hidden');
                closeModal();
            }, 'image/jpeg');
        }

        function removeImage(id) {
            const input = document.getElementById(id);
            const img = document.getElementById('img-' + id);
            const icon = document.getElementById('icon-' + id);
            const container = document.getElementById('container-' + id);
            const existing = document.getElementById('existing-' + id);

            input.value = "";
            img.src = "";
            img.classList.add('hidden');
            if (icon) icon.classList.remove('hidden');
            container.querySelector('.remove-img-btn').classList.add('hidden');
            if (existing) existing.remove();
        }

        function addNewVariant() {
            const section = document.getElementById('variantsSection');
            const div = document.createElement('div');
            div.className = 'glass-card variant-card relative';
            let imgHtml = '';
            for (let i = 0; i < 4; i++) {
                const id = `v${variantCount}-input-${i}`;
                imgHtml += `<div class="image-container" id="container-${id}"><button type="button" class="remove-img-btn hidden" onclick="removeImage('${id}')"><i class="fas fa-times"></i></button><div class="image-upload-box" onclick="document.getElementById('${id}').click()"><i class="fas fa-image text-neutral-600 text-xl" id="icon-${id}"></i><img src="" id="img-${id}" class="hidden"><input type="file" id="${id}" name="variants[${variantCount}][images]" class="hidden" accept="image/*" onchange="initCropper(event, '${id}')"></div></div>`;
            }
            div.innerHTML = `<button type="button" onclick="this.parentElement.remove()" class="absolute top-4 right-4 text-zinc-500 hover:text-red-500"><i class="fas fa-trash"></i></button><label class="form-label">Color</label><select name="variants[${variantCount}][color]" class="input-field"><option>Black</option><option>White</option><option>Red</option><option>Blue</option></select><div class="grid grid-cols-2 gap-4 mt-6"><input type="number" name="variants[${variantCount}][regularPrice]" placeholder="Reg Price" class="input-field reg-price"><input type="number" name="variants[${variantCount}][salePrice]" placeholder="Sale Price" class="input-field sale-price"></div><input type="number" name="variants[${variantCount}][quantity]" placeholder="Qty" class="input-field qty-field mt-6"><div class="grid grid-cols-4 gap-4 mt-6">${imgHtml}</div>`;
            section.appendChild(div);
            variantCount++;
        }
    </script>
</body>
</html>