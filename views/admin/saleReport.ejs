<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report | Luxury Watches</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        body { background-color: #0d0d0d; color: #ffffff; }
        .card { background-color: #141414; border: 1px solid #262626; }
        input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }
        
        /* Custom scrollbar for dark theme */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #0d0d0d; }
        ::-webkit-scrollbar-thumb { background: #262626; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #333; }
    </style>
</head>
<body class="flex min-h-screen">
    <%- include('../partials/admin/sidebar') %>

    <main class="flex-1 p-8">
        <header class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6 mb-8">
            <div>
                <h1 class="text-3xl font-bold">Sales Report</h1>
                <p class="text-gray-500 tracking-wide">Detailed analytics for <strong><%= data.filter.toUpperCase() %></strong></p>
            </div>

            <div class="flex flex-wrap items-center gap-4 bg-[#141414] p-4 rounded-xl border border-gray-800 shadow-xl">
                <select id="reportRange" onchange="handleRangeChange()" class="bg-[#1a1a1a] border border-gray-700 text-sm rounded-lg p-2 outline-none focus:border-blue-500 transition">
                    <option value="all" <%= data.filter === 'all' ? 'selected' : '' %>>All Time</option>
                    <option value="today" <%= data.filter === 'today' ? 'selected' : '' %>>Today</option>
                    <option value="weekly" <%= data.filter === 'weekly' ? 'selected' : '' %>>Weekly</option>
                    <option value="monthly" <%= data.filter === 'monthly' ? 'selected' : '' %>>Monthly</option>
                    <option value="yearly" <%= data.filter === 'yearly' ? 'selected' : '' %>>Yearly</option>
                    <option value="custom" <%= data.filter === 'custom' ? 'selected' : '' %>>Custom Range</option>
                </select>

                <div id="customDateRange" class="<%= data.filter === 'custom' ? 'flex' : 'hidden' %> items-center gap-2">
                    <input type="date" id="startDate" value="<%= data.startDate %>" class="bg-[#1a1a1a] border border-gray-700 text-sm rounded-lg p-2 outline-none">
                    <span class="text-gray-600">to</span>
                    <input type="date" id="endDate" value="<%= data.endDate %>" class="bg-[#1a1a1a] border border-gray-700 text-sm rounded-lg p-2 outline-none">
                    <button onclick="applyFilters()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-semibold transition">Apply</button>
                </div>

                <button onclick="confirmExport()" class="bg-green-600 hover:bg-green-700 px-5 py-2 rounded-lg text-sm font-bold flex items-center gap-2 transition transform active:scale-95 shadow-lg shadow-green-900/20">
                    <i class="fas fa-file-pdf"></i> Export PDF
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="card p-6 rounded-xl border-l-4 border-l-green-500 hover:translate-y-[-4px] transition duration-300">
                <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Total Revenue</p>
                <h2 class="text-2xl font-black mt-2">₹<%= data.stats.totalRevenue.toLocaleString('en-IN') %></h2>
            </div>
            <div class="card p-6 rounded-xl border-l-4 border-l-blue-500 hover:translate-y-[-4px] transition duration-300">
                <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Orders Count</p>
                <h2 class="text-2xl font-black mt-2"><%= data.stats.totalOrders %></h2>
            </div>
            <div class="card p-6 rounded-xl border-l-4 border-l-orange-500 hover:translate-y-[-4px] transition duration-300">
                <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Avg. Ticket Size</p>
                <h2 class="text-2xl font-black mt-2">₹<%= data.stats.avgOrderValue.toLocaleString('en-IN') %></h2>
            </div>
            <div class="card p-6 rounded-xl border-l-4 border-l-red-500 hover:translate-y-[-4px] transition duration-300">
                <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Total Discounts</p>
                <h2 class="text-2xl font-black mt-2 text-red-400">₹<%= data.stats.totalDiscount.toLocaleString('en-IN') %></h2>
            </div>
        </div>

        <div class="card rounded-xl overflow-hidden shadow-2xl">
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-black/50 text-gray-400 text-xs uppercase tracking-widest">
                        <tr>
                            <th class="p-4 border-b border-gray-800">Order ID</th>
                            <th class="p-4 border-b border-gray-800">Date</th>
                            <th class="p-4 border-b border-gray-800">Customer</th>
                            <th class="p-4 border-b border-gray-800">Method</th>
                            <th class="p-4 border-b border-gray-800">Status</th>
                            <th class="p-4 border-b border-gray-800 text-right">Amount</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-800">
                        <% if(data.recentOrders.length > 0) { %>
                            <% data.recentOrders.forEach(order => { %>
                            <tr class="hover:bg-gray-800/40 transition">
                                <td class="p-4 text-sm font-mono text-blue-500">#<%= order.id %></td>
                                <td class="p-4 text-sm text-gray-400">
                                    <%= new Date(order.date).toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                </td>
                                <td class="p-4 text-sm font-medium"><%= order.customer %></td>
                                <td class="p-4 text-xs text-gray-500 font-bold"><%= order.payment || 'COD' %></td>
                                <td class="p-4">
                                    <span class="px-2 py-1 rounded text-[10px] font-bold uppercase 
                                        <%= order.status.toLowerCase() === 'delivered' ? 'bg-green-900/30 text-green-400 border border-green-800/50' : 
                                           order.status.toLowerCase() === 'pending' ? 'bg-yellow-900/30 text-yellow-400 border border-yellow-800/50' : 
                                           'bg-gray-800 text-gray-400 border border-gray-700' %>">
                                        <%= order.status %>
                                    </span>
                                </td>
                                <td class="p-4 text-sm font-bold text-right text-white">
                                    ₹<%= (order.amount || 0).toLocaleString('en-IN') %>
                                </td>
                            </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="p-16 text-center">
                                    <div class="flex flex-col items-center gap-2">
                                        <i class="fas fa-box-open text-4xl text-gray-800"></i>
                                        <p class="text-gray-600 font-medium">No orders found for the selected period.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <script>
        // ടൈം റേഞ്ച് മാറ്റുമ്പോൾ പേജ് റീലോഡ് ചെയ്യും
        function handleRangeChange() {
            const range = document.getElementById('reportRange').value;
            if (range === 'custom') {
                document.getElementById('customDateRange').classList.remove('hidden');
            } else {
                window.location.href = `/admin/sales-report?range=${range}`;
            }
        }

        // കസ്റ്റം ഡേറ്റ് അപ്ലൈ ചെയ്യുമ്പോൾ
        function applyFilters() {
            const range = document.getElementById('reportRange').value;
            const start = document.getElementById('startDate').value;
            const end = document.getElementById('endDate').value;
            if (start && end) {
                window.location.href = `/admin/sales-report?range=${range}&start=${start}&end=${end}`;
            } else {
                Swal.fire({
                    icon: 'warning',
                    title: 'Missing Dates',
                    text: 'Please select both start and end dates.',
                    background: '#141414',
                    color: '#fff'
                });
            }
        }

        // എക്സ്പോർട്ട് ചെയ്യുന്നതിന് മുൻപുള്ള കൺഫർമേഷൻ
        function confirmExport() {
            const range = document.getElementById('reportRange').value;
            const rangeText = range === 'all' ? 'All Time' : range.charAt(0).toUpperCase() + range.slice(1);

            Swal.fire({
                title: 'Download Report?',
                text: `Do you want to export the ${rangeText} sales report as a PDF document?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#059669', // Tailwind green-600
                cancelButtonColor: '#374151',  // Tailwind gray-700
                confirmButtonText: '<i class="fas fa-download mr-2"></i>Yes, Export',
                cancelButtonText: 'Cancel',
                background: '#141414',
                color: '#ffffff',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    executePDFDownload();
                }
            });
        }

        // ഫിൽട്ടർ ചെയ്ത വാല്യൂസ് വെച്ച് PDF ഡൗൺലോഡ് ചെയ്യും
        function executePDFDownload() {
            const range = document.getElementById('reportRange').value;
            const start = document.getElementById('startDate').value;
            const end = document.getElementById('endDate').value;
            
            // URL കൺസ്ട്രക്ഷൻ - നിലവിലെ സെലക്ഷൻ തന്നെ കൺട്രോളറിലേക്ക് അയക്കുന്നു
            let url = `/admin/sales-report/download/pdf?range=${range}`;
            
            if (range === 'custom' && start && end) {
                url += `&startDate=${start}&endDate=${end}`;
            }
            
            // ലോഡിംഗ് സ്റ്റേറ്റ് കാണിക്കണമെങ്കിൽ Swal ഉപയോഗിക്കാം
            Swal.fire({
                title: 'Generating PDF...',
                html: 'Please wait while we prepare your luxury report.',
                timerProgressBar: true,
                didOpen: () => {
                    Swal.showLoading();
                },
                background: '#141414',
                color: '#fff',
                timer: 1500,
                showConfirmButton: false
            });

            // ഡൗൺലോഡ് ട്രിഗർ ചെയ്യുന്നു
            window.location.href = url;
        }
    </script>
</body>
</html>