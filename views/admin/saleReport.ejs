<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Report | Luxury Watches</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0d0d0d; color: #ffffff; }
        .card { background-color: #141414; border: 1px solid #262626; }
        .modal-card { background-color: #1a1a1a; border: 1px solid #333; }
        input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }
    </style>
</head>
<body class="flex min-h-screen">

    <%- include('../partials/admin/sidebar') %>

    <main class="flex-1 p-8">
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold">Sales Report</h1>
                <p class="text-gray-500">Welcome back, <%= data.adminName %></p>
            </div>
            <div class="flex gap-3">
                <button onclick="toggleModal()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded text-sm font-medium flex items-center gap-2">
                    <i class="fas fa-download"></i> Download Report
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="card p-6 rounded-xl text-center">
                <p class="text-gray-400 text-sm">Total Revenue</p>
                <h2 class="text-2xl font-bold mt-1 text-green-500">₹<%= data.stats.totalRevenue %></h2>
            </div>
            <div class="card p-6 rounded-xl text-center">
                <p class="text-gray-400 text-sm">Total Orders</p>
                <h2 class="text-2xl font-bold mt-1"><%= data.stats.totalOrders %></h2>
            </div>
            <div class="card p-6 rounded-xl text-center">
                <p class="text-gray-400 text-sm">Avg Order Value</p>
                <h2 class="text-2xl font-bold mt-1 text-blue-400">₹<%= data.stats.avgOrderValue %></h2>
            </div>
            <div class="card p-6 rounded-xl text-center">
                <p class="text-gray-400 text-sm">New Customers</p>
                <h2 class="text-2xl font-bold mt-1 text-purple-400"><%= data.stats.newCustomers %></h2>
            </div>
        </div>

        <div class="card rounded-xl overflow-hidden">
            <div class="p-6 border-b border-gray-800 flex justify-between">
                <h3 class="font-semibold">Recent Transactions</h3>
            </div>
            <table class="w-full text-left">
                <thead class="bg-gray-900/50 text-gray-400 text-xs uppercase">
                    <tr>
                        <th class="p-4">Order ID</th>
                        <th class="p-4">Date</th>
                        <th class="p-4">Customer</th>
                        <th class="p-4">Status</th>
                        <th class="p-4 text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800">
                    <% if(data.recentOrders && data.recentOrders.length > 0) { %>
                        <% data.recentOrders.forEach(order => { %>
                        <tr class="hover:bg-gray-900/30 transition">
                            <td class="p-4 text-sm font-mono">#<%= order.id %></td>
                            <td class="p-4 text-sm text-gray-400"><%= order.date %></td>
                            <td class="p-4 text-sm"><%= order.customer %></td>
                            <td class="p-4">
                                <span class="px-2 py-1 rounded-full text-[10px] font-bold uppercase 
                                    <%= order.status === 'Delivered' ? 'bg-green-900 text-green-300' : 
                                       order.status === 'Pending' ? 'bg-yellow-900 text-yellow-300' : 
                                       order.status === 'Shipped' ? 'bg-blue-900 text-blue-300' : 'bg-red-900 text-red-300' %>">
                                    <%= order.status %>
                                </span>
                            </td>
                            <td class="p-4 text-sm font-semibold text-right text-blue-400">₹<%= order.amount %></td>
                        </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" class="p-8 text-center text-gray-500">No data available</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <div id="downloadModal" class="fixed inset-0 bg-black bg-opacity-70 z-50 flex items-center justify-center hidden">
        <div class="modal-card p-8 rounded-2xl w-full max-w-sm shadow-2xl">
            <div class="flex justify-between items-center mb-6">
                <h3 class="text-xl font-bold">Download Report</h3>
                <button onclick="toggleModal()" class="text-gray-500 hover:text-white"><i class="fas fa-times"></i></button>
            </div>
            <div class="flex flex-col gap-4">
                <a href="/admin/sales-report/download/pdf" class="flex items-center justify-between bg-gray-800 hover:bg-red-900 p-4 rounded-xl transition border border-gray-700">
                    <span class="flex items-center gap-3"><i class="fas fa-file-pdf text-red-500"></i> PDF Document</span>
                </a>
                <a href="/admin/sales-report/download/excel" class="flex items-center justify-between bg-gray-800 hover:bg-green-900 p-4 rounded-xl transition border border-gray-700">
                    <span class="flex items-center gap-3"><i class="fas fa-file-excel text-green-500"></i> Excel Sheet</span>
                </a>
            </div>
        </div>
    </div>

    <script>
        function toggleModal() {
            document.getElementById('downloadModal').classList.toggle('hidden');
        }
    </script>
</body>
</html>