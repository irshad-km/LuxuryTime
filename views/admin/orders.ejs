<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Order Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        body {
            background-color: #08090a;
            color: #a0a0a8;
        }

        .sidebar-active {
            background-color: #1a1c23;
            color: #3b82f6;
            border-radius: 8px;
        }

        .status-pill {
            padding: 2px 12px;
            border-radius: 999px;
            font-size: 11px;
            border: 1px solid transparent;
            display: inline-block;
        }

        /* Pagination Box Style */
        .page-box {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            border: 1px solid #1f2937;
            text-decoration: none;
            color: #9ca3af;
            font-size: 12px;
            transition: 0.2s;
        }

        .page-box.active {
            background: #2563eb;
            color: white;
            border-color: #2563eb;
        }

        .page-box:hover:not(.active) {
            background: #1f2937;
            color: white;
        }
    </style>
</head>

<body class="flex h-screen overflow-hidden">

    <%- include('../partials/admin/sidebar') %>

    <main class="flex-1 overflow-y-auto p-12">
        <header class="mb-8">
            <h1 class="text-3xl font-bold text-white mb-1">Order Management</h1>
            <p class="text-gray-500 text-sm">Manage & track customer orders</p>
        </header>

        <form action="/admin/orders" method="GET" class="flex gap-0 mb-8">
            <div class="relative flex-1">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
                <input type="text" name="search" value="<%= search %>" placeholder="Search by Customer Name"
                    class="w-full bg-[#1a1c23] border border-gray-700 rounded-l-xl py-3.5 pl-12 pr-4 focus:outline-none focus:border-blue-500 text-sm text-white">
            </div>
            <button type="submit"
                class="bg-[#2563eb] text-white px-10 rounded-r-xl font-semibold hover:bg-blue-600 transition">Search</button>
            <% if (search) { %>
                <a href="/admin/orders" class="ml-4 flex items-center text-sm text-red-400 hover:text-red-300">Clear</a>
            <% } %>
        </form>

        <div class="bg-[#0f1115] border border-gray-800 rounded-2xl overflow-hidden">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="text-[10px] uppercase tracking-widest text-gray-500 border-b border-gray-800">
                        <th class="px-6 py-5 font-semibold">Customer Name</th>
                        <th class="px-6 py-4 font-semibold">Order Date</th>
                        <th class="px-6 py-4 font-semibold text-gray-300">Amount (₹)</th>
                        <th class="px-6 py-4 font-semibold">Payment Method</th>
                        <th class="px-6 py-4 font-semibold">Delivery Status</th>
                        <th class="px-6 py-4 font-semibold text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-800/50">
                    <% orders.forEach(order=> { %>
                        <tr class="hover:bg-white/5 transition-colors">

                            <td class="px-6 py-5 text-white">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-9 h-9 rounded-full bg-[#1a1c23] border border-gray-700 overflow-hidden flex items-center justify-center">
                                        <% if (order.userProfileImage) { %>
                                            <img src="/uploads/re-image/<%= order.userProfileImage %>" alt="User"
                                                class="w-full h-full object-cover">
                                            <% } else { %>
                                                <i class="fa-solid fa-user text-gray-600 text-xs"></i>
                                                <% } %>
                                    </div>

                                    <span class="font-medium">
                                        <% orders.forEach(order=>{%>
                                            <%=order.address.fullname%>
                                       <% }) %>
                                    </span>
                                </div>
                            </td>

                            <td class="px-6 py-5 text-gray-400">
                                <%= new Date(order.createdAt).toLocaleDateString('en-GB', { day: '2-digit' ,
                                    month: 'short' , year: 'numeric' }) %>
                            </td>

                            <td class="px-6 py-5 font-bold text-gray-200">
                                ₹<%= order.totalAmount.toLocaleString() %>
                            </td>

                            <td class="px-6 py-5 text-gray-400 text-xs">
                                <%= order.paymentMethod %>
                            </td>

                            <td class="px-6 py-5">
                                <% let statusStyles="" ; if(order.orderStatus==='Shipped' )
                                    statusStyles="bg-blue-500/10 text-blue-400 border-blue-500/30" ; else
                                    if(order.orderStatus==='Delivered' )
                                    statusStyles="bg-green-500/10 text-green-400 border-green-500/30" ; else
                                    if(order.orderStatus==='Pending' )
                                    statusStyles="bg-gray-500/10 text-gray-400 border-gray-500/30" ; else
                                    if(order.orderStatus==='Cancelled' )
                                    statusStyles="bg-red-500/10 text-red-400 border-red-500/30" ; else
                                    if(order.orderStatus==='Out for Delivery' )
                                    statusStyles="bg-yellow-500/10 text-yellow-500/80 border-yellow-500/30" ; %>
                                    <span class="status-pill <%= statusStyles %>">
                                        <%= order.orderStatus %>
                                    </span>
                            </td>

                            <td class="px-6 py-5 text-right space-x-3">
                                <a href="/admin/orders/<%= order._id %>"
                                    class="text-blue-500 text-xs font-semibold hover:underline">
                                    View
                                </a>
                            </td>
                        </tr>
                        <% }) %>
                </tbody>
            </table>

            <div class="px-6 py-5 flex items-center justify-between border-t border-gray-800">
                <span class="text-xs text-gray-500 uppercase tracking-widest font-bold">
                    Page <%= currentPage %> of <%= totalPages %>
                </span>
                <div class="flex gap-2">
                    <% for(let i=1; i<=totalPages; i++) { %>
                        <a href="?page=<%= i %><%= search ? '&search=' + search : '' %>" 
                           class="page-box <%= i === currentPage ? 'active' : '' %>">
                            <%= i %>
                        </a>
                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <script>
        async function cancelOrder(orderId) {
            const result = await Swal.fire({
                title: 'Cancel Order?',
                text: "Are you sure you want to cancel this order?",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#1f2937',
                confirmButtonText: 'Yes, Cancel it',
                background: '#0f1115',
                color: '#fff'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/orders/cancel/${orderId}`, { method: 'POST' });
                    if (response.ok) {
                        Swal.fire({
                            title: 'Cancelled!',
                            icon: 'success',
                            background: '#0f1115',
                            color: '#fff',
                            showConfirmButton: false,
                            timer: 1500
                        }).then(() => location.reload());
                    }
                } catch (err) {
                    console.error(err);
                }
            }
        }
    </script>
</body>

</html>