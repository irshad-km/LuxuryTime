<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Category Management | Luxury Watches</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --bg-main: #000000;
            --bg-card: #0a0a0a;
            --bg-input: #1a1a1a;
            --accent-blue: #5350e9;
            --text-muted: #666666;
            --border-color: #222222;
        }

        body {
            background-color: var(--bg-main);
            color: #ffffff;
            font-family: 'Inter', sans-serif;
        }

        .modal-overlay {
            background-color: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(4px);
        }

        .modal-content {
            background-color: #000000;
            border: 1px solid #1a1a1a;
            width: 450px;
        }

        .input-field {
            background-color: #1a1a1a;
            border: 1px solid #222;
            color: white;
            border-radius: 8px;
            width: 100%;
            padding: 12px;
        }

        .status-badge {
            padding: 4px 12px;
            border-radius: 9999px;
            font-size: 0.75rem;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .status-active {
            color: #10b981;
            background: rgba(16, 185, 129, 0.1);
        }

        .status-inactive {
            color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
        }

        .offer-tag {
            background: rgba(139, 92, 246, 0.1);
            color: #a78bfa;
            border: 1px solid rgba(139, 92, 246, 0.2);
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 0.7rem;
        }

        .switch {
            position: relative;
            display: inline-block;
            width: 40px;
            height: 20px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #333;
            transition: .4s;
            border-radius: 34px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 14px;
            width: 14px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }

        input:checked+.slider {
            background-color: #10b981;
        }

        input:checked+.slider:before {
            transform: translateX(20px);
        }

        .btn-primary {
            background-color: var(--accent-blue);
        }

        .btn-secondary {
            background-color: #222;
        }

        .hidden {
            display: none;
        }

        /* Dark Theme SweetAlert Styling */
        .swal2-popup {
            background-color: #0a0a0a !important;
            color: white !important;
            border: 1px solid #222 !important;
            border-radius: 15px !important;
        }
    </style>
</head>

<body class="flex">

    <%- include('../partials/admin/sidebar') %>

    <div class="flex-1 min-h-screen flex flex-col">
        <nav class="px-8 py-4 flex justify-between items-center">
            <div class="text-xs text-gray-500">
                Admin <span class="mx-2">›</span> <span class="text-gray-300">Category Management</span>
            </div>
        </nav>

        <main class="px-10 py-6 max-w-6xl mx-auto w-full">
            <div class="flex justify-between items-start mb-8">
                <div>
                    <h1 class="text-4xl font-semibold tracking-tight">Category Management</h1>
                    <p class="text-gray-500 mt-2">Organize and manage your product catalog hierarchy.</p>
                </div>
                <button onclick="openCategoryModal('add')"
                    class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-lg flex items-center gap-2 font-medium transition shadow-lg shadow-blue-900/20">
                    <i class="fas fa-plus"></i> Add New Category
                </button>
            </div>

            <div class="category-table-container border border-[#1a1a1a] bg-[#0a0a0a] rounded-xl overflow-hidden">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="border-b border-gray-900">
                            <th class="px-8 py-5 text-gray-500 text-xs uppercase tracking-wider">Category Name</th>
                            <th class="px-8 py-5 text-gray-500 text-xs uppercase tracking-wider">Description</th>
                            <th class="px-8 py-5 text-gray-500 text-xs uppercase tracking-wider text-center">Offer</th>
                            <th class="px-8 py-5 text-gray-500 text-xs uppercase tracking-wider text-center">Status</th>
                            <th class="px-8 py-5 text-gray-500 text-xs uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-900/50">
                        <% if (typeof categories !=='undefined' && categories.length > 0) { %>
                            <% categories.forEach(cat => { %>
                                <tr class="hover:bg-white/[0.02] transition">
                                    <td class="px-8 py-6 font-bold tracking-widest text-sm uppercase">
                                        <%= cat.name %>
                                    </td>
                                    <td class="px-8 py-6 text-xs text-gray-400 max-w-xs truncate">
                                        <%= cat.description || '—' %>
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        <% if (cat.offer && cat.offer > 0) { %>
                                            <span class="offer-tag"><%= cat.offer %>% OFF</span>
                                        <% } else { %> — <% } %>
                                    </td>
                                    <td class="px-8 py-6 text-center">
                                        <span class="status-badge <%= cat.isListed ? 'status-active' : 'status-inactive' %>">
                                            <span class="w-1.5 h-1.5 rounded-full <%= cat.isListed ? 'bg-emerald-500' : 'bg-red-500' %>"></span>
                                            <%= cat.isListed ? 'Active' : 'Inactive' %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <div class="flex justify-end items-center gap-4">
                                            <button onclick="openCategoryModal('edit', '<%= JSON.stringify(cat) %>')"
                                                class="bg-[#2e37a4] px-4 py-1.5 rounded text-[10px] font-bold hover:bg-blue-600 transition uppercase">Edit</button>

                                            <div class="flex items-center gap-2">
                                                <span class="text-[10px] font-bold text-gray-500 uppercase">
                                                    <%= cat.isListed ? 'Unlist' : 'List' %>
                                                </span>
                                                <label class="switch">
                                                    <input type="checkbox" <%=cat.isListed ? 'checked' : '' %>
                                                        onchange="confirmToggleStatus('<%= cat._id %>', this)">
                                                    <span class="slider"></span>
                                                </label>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="px-8 py-10 text-center text-gray-600 italic">No categories found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <div id="categoryModal" class="hidden fixed inset-0 z-50 flex items-center justify-center modal-overlay">
        <div class="modal-content p-8 rounded-2xl shadow-2xl relative">
            <h2 id="modalTitle" class="text-2xl font-bold mb-6">Add Category</h2>

            <form id="categoryForm" action="/admin/addCategory" method="POST">
                <input type="hidden" name="categoryId" id="categoryId">

                <div class="mb-5">
                    <label class="block text-sm font-medium text-gray-300 mb-2">Category Name</label>
                    <input type="text" name="name" id="catName" class="input-field" placeholder="Enter name" required>
                </div>
                <div class="mb-5">
                    <label class="block text-sm font-medium text-gray-300 mb-2">Description <span class="text-gray-600">(Optional)</span></label>
                    <textarea name="description" id="catDesc" rows="4" class="input-field resize-none"></textarea>
                </div>

                <div class="mb-5">
                    <label class="block text-sm font-medium text-gray-300 mb-2">Offer (%)</label>
                    <input type="number" name="offer" id="catOffer" class="input-field" placeholder="0" min="0" max="99">
                </div>
                <div class="mb-8">
                    <label class="block text-sm font-medium text-gray-300 mb-2">Offer Expiry Date</label>
                    <input type="date" name="offerExpiry" id="catExpiry" class="input-field text-gray-400">
                </div>
                <div class="border-t border-gray-900 pt-6 mt-6 flex gap-4">
                    <button type="submit" class="flex-1 btn-primary py-3 rounded-xl font-semibold hover:opacity-90 transition">Save</button>
                    <button type="button" onclick="closeModal()" class="flex-1 btn-secondary py-3 rounded-xl font-semibold text-gray-300 hover:bg-gray-800 transition">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        const modal = document.getElementById('categoryModal');
        const form = document.getElementById('categoryForm');
        const title = document.getElementById('modalTitle');

        function openCategoryModal(mode, data = null) {
            modal.classList.remove('hidden');
            if (mode === 'add') {
                title.innerText = 'Add Category';
                form.action = '/admin/addCategory';
                form.reset();
            } else {
                title.innerText = 'Edit Category';
                const category = JSON.parse(data);
                form.action = `/admin/editCategory/${category._id}`;
                document.getElementById('catName').value = category.name;
                document.getElementById('catDesc').value = category.description || "";
                document.getElementById('catOffer').value = category.offer || "";
                if (category.offerExpiry) {
                    document.getElementById('catExpiry').value = new Date(category.offerExpiry).toISOString().split('T')[0];
                } else {
                    document.getElementById('catExpiry').value = "";
                }
            }
        }

        function closeModal() {
            modal.classList.add('hidden');
        }

        // --- Confirmation Popup Logic ---
        async function confirmToggleStatus(categoryId, checkbox) {
            const isListing = checkbox.checked;
            const actionText = isListing ? "List" : "Unlist";

            // Revert checkbox visually until confirmed
            checkbox.checked = !isListing;

            const result = await Swal.fire({
                title: 'Are you sure?',
                text: `Do you want to ${actionText} this category?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#5350e9',
                cancelButtonColor: '#222',
                confirmButtonText: `Yes, ${actionText} it!`,
                background: '#0a0a0a',
                color: '#fff'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/admin/toggleCategory/${categoryId}`, { method: 'PATCH' });
                    if (response.ok) {
                        checkbox.checked = isListing; // Update visual state
                        window.location.reload();
                    } else {
                        Swal.fire('Error', 'Failed to update status', 'error');
                    }
                } catch (err) {
                    console.error('Toggle status error:', err);
                }
            }
        }

        window.onclick = function (event) {
            if (event.target === modal) closeModal();
        }
    </script>
</body>

</html>