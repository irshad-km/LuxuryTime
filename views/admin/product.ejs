<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin | Product Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');

    :root {
      --bg-main: #050505;
      --card-bg: #111111;
      --border-subtle: #1f1f1f;
      --accent-blue: #2563eb;
      --text-gray: #a1a1aa;
    }

    body {
      background-color: var(--bg-main);
      color: #ffffff;
      font-family: 'Plus Jakarta Sans', sans-serif;
      letter-spacing: -0.01em;
      margin: 0;
      overflow-x: hidden;
    }

    .admin-wrapper {
      display: flex;
      min-height: 100vh;
    }

    .main-content {
      flex-grow: 1;
      padding: 2rem;
      width: calc(100% - 260px);
    }

    .glass-panel {
      background: rgba(17, 17, 17, 0.6);
      backdrop-filter: blur(10px);
      border: 1px solid var(--border-subtle);
      border-radius: 16px;
    }

    .custom-table th {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: #555;
      padding: 20px 24px;
      border-bottom: 1px solid var(--border-subtle);
    }

    .custom-table td {
      padding: 16px 24px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.03);
      vertical-align: middle;
    }

    .status-active {
      background: rgba(16, 185, 129, 0.1);
      color: #10b981;
      font-size: 10px;
      padding: 4px 10px;
      border-radius: 6px;
      font-weight: 700;
    }

    .status-inactive {
      background: rgba(107, 114, 128, 0.1);
      color: #9ca3af;
      font-size: 10px;
      padding: 4px 10px;
      border-radius: 6px;
      font-weight: 700;
    }

    .search-container {
      background: #111;
      border: 1px solid var(--border-subtle);
      border-radius: 10px;
    }

    .btn-action {
      width: 32px;
      height: 32px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.03);
      transition: all 0.2s;
    }

    .btn-edit:hover {
      color: #3b82f6;
      background: rgba(59, 130, 246, 0.1);
    }

    .btn-delete:hover {
      color: #ef4444;
      background: rgba(239, 68, 68, 0.1);
    }

    .offer-badge {
      background: rgba(37, 99, 235, 0.1);
      color: #3b82f6;
      border: 1px solid rgba(37, 99, 235, 0.2);
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 4px;
    }
  </style>
</head>

<body>

  <div class="admin-wrapper">
    <aside>
      <%- include('../partials/admin/sidebar') %>
    </aside>

    <main class="main-content">

      <header class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-6">
        <div>
          <h1 class="text-3xl font-bold mb-1 tracking-tight">Product Management</h1>
          <p class="text-neutral-500 text-sm">Manage your luxury watch inventory and pricing</p>
        </div>

        <div class="flex items-center gap-4 w-full md:w-auto">
          <div class="search-container flex items-center px-4 py-2 w-full md:w-80 border border-neutral-800">
            <i class="fas fa-search text-neutral-600 mr-3"></i>
            <input type="text" placeholder="Search by product name..."
              class="bg-transparent border-none outline-none text-sm w-full text-white">
            <button class="bg-neutral-800 text-xs px-2 py-1 rounded text-neutral-400 hover:text-white transition">
              <i class="fas fa-arrow-right"></i>
            </button>
          </div>
          <a href="/admin/addproduct">
            <button
              class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-xl font-semibold text-sm flex items-center gap-2 transition shadow-lg shadow-blue-900/20 whitespace-nowrap">
              <i class="fas fa-plus text-xs"></i>
              Add Product
            </button>
          </a>
        </div>
      </header>

      <div class="glass-panel overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-left custom-table border-collapse">
            <thead>
              <tr>
                <th>Image</th>
                <th>Product Name</th>
                <th>Category</th>
                <th>Regular Price (₹)</th>
                <th>Sale Price (₹)</th>
                <th>Qty</th>
                <th>Status</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="text-sm">
              <% products.forEach(product=> { %>
                <tr class="hover:bg-white/[0.02] transition">
                  <td>
                    <div
                      class="w-12 h-12 bg-neutral-900 rounded-full border border-neutral-800 flex items-center justify-center overflow-hidden p-2">
                      <img src="<%= product.variants[0]?.images[0] || 'https://via.placeholder.com/40' %>" alt="Watch"
                        class="w-full h-full object-contain opacity-80">
                    </div>
                  </td>
                  <td>
                    <div class="font-semibold text-neutral-100">
                      <%= product.name %>
                    </div>
                  </td>
                  <td class="text-neutral-400">
                    <%= product.category?.name || 'Uncategorized' %>
                  </td>
                  <td class="text-neutral-300 font-medium">₹ <%= product.variants[0]?.regularPrice?.toLocaleString() ||
                      0 %>
                  </td>
                  <td class="text-neutral-100 font-bold">
                    <%= product.variants[0]?.salePrice ? '₹ ' + product.variants[0].salePrice.toLocaleString() : '-' %>
                  </td>
                  <td class="text-neutral-300">
                    <%= product.variants[0]?.quantity || 0 %>
                  </td>
                  <td>
                    <span class="<%= product.isListed ? 'status-inactive' : 'status-active' %>">
                      <%= product.isListed ? 'INACTIVE' : 'ACTIVE' %>
                    </span>
                  </td>
                  <td class="text-right">
                    <div class="flex justify-end gap-2">
                      <a href="/admin/products/edit/<%= product._id %>">
                        <button class="btn-action btn-edit" title="Edit">
                          <i class="fas fa-pencil-alt text-xs"></i>
                        </button>
                      </a>

                      <button class="btn-action btn-delete" title="Delete">
                        <i class="fas fa-trash-alt text-xs"></i>
                      </button>
                    </div>
                  </td>
                </tr>
                <% }) %>
            </tbody>
          </table>
        </div>

        <div
          class="p-6 flex flex-col md:flex-row justify-between items-center gap-4 border-t border-neutral-900/50 bg-neutral-900/20">
          <p class="text-xs text-neutral-500">Showing <span class="text-neutral-300 font-bold">1-5</span> of
            <span class="text-neutral-300 font-bold">
              <%= products.length %>
            </span> results
          </p>

          <div class="flex gap-2">
            <button
              class="px-4 py-2 bg-neutral-900 border border-neutral-800 rounded-lg text-xs font-bold text-neutral-500 hover:text-white transition disabled:opacity-50">Previous</button>
            <button
              class="px-5 py-2 bg-blue-600 rounded-lg text-xs font-bold text-white shadow-lg shadow-blue-900/40">Next</button>
          </div>
        </div>
      </div>
    </main>
  </div>
</body>

</html>