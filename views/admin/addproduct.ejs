<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin | Add New Product</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css">

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');

        :root {
            --bg-main: #050505;
            --card-bg: #111111;
            --input-bg: #1a1a1a;
            --border-subtle: #262626;
            --accent-blue: #2563eb;
        }

        body {
            background-color: var(--bg-main);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        .main-content {
            flex-grow: 1;
            padding: 3rem;
            width: calc(100% - 260px);
        }

        .glass-card {
            background: var(--card-bg);
            border: 1px solid var(--border-subtle);
            border-radius: 16px;
            padding: 2rem;
            margin-bottom: 2rem;
            position: relative;
        }

        .form-label {
            font-size: 13px;
            font-weight: 600;
            color: #a1a1aa;
            margin-bottom: 8px;
            display: block;
        }

        .input-field {
            background: var(--input-bg);
            border: 1px solid var(--border-subtle);
            color: white;
            border-radius: 8px;
            padding: 12px 16px;
            width: 100%;
            outline: none;
        }

        .image-upload-box {
            border: 2px dashed var(--border-subtle);
            border-radius: 12px;
            height: 180px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
            overflow: hidden;
            background: #0d0d0d;
            position: relative;
        }

        .image-upload-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .img-delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(239, 68, 68, 0.9);
            color: white;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            z-index: 10;
            transition: 0.2s;
        }

        #successModal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(8px);
            z-index: 10000;
            align-items: center;
            justify-content: center;
        }

        .success-card {
            background: #111;
            padding: 40px;
            border-radius: 24px;
            text-align: center;
            border: 1px solid #222;
            transform: scale(0.9);
            animation: popIn 0.3s forwards;
        }

        @keyframes popIn {
            to { transform: scale(1); }
        }

        #cropperModal {
            background: rgba(0, 0, 0, 0.9);
            display: none;
            position: fixed;
            inset: 0;
            z-index: 9999;
            align-items: center;
            justify-content: center;
        }

        .modal-content-wrapper {
            background: #111;
            padding: 24px;
            border-radius: 20px;
            width: 90%;
            max-width: 600px;
        }
    </style>
</head>

<body>

    <div id="successModal">
        <div class="success-card">
            <div class="w-20 h-20 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="fas fa-check text-4xl"></i>
            </div>
            <h2 class="text-2xl font-bold mb-2">Creating Product...</h2>
            <p class="text-zinc-400 mb-8">Please wait while we upload your product data.</p>
            <div class="flex gap-3 justify-center">
                <span class="text-sm text-zinc-500 italic">Processing images...</span>
            </div>
        </div>
    </div>

    <div id="toastContainer" class="fixed top-6 right-6 z-[9999] flex flex-col gap-4">
        <% if (locals.error) { %>
            <div class="bg-red-600 text-white px-6 py-4 rounded-xl shadow-xl flex gap-4">
                <i class="fas fa-circle-exclamation text-xl"></i>
                <div class="flex-1">
                    <p class="text-sm font-medium"><%= error %></p>
                </div>
                <button onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>
            </div>
        <% } %>
    </div>

    <div class="admin-wrapper">
        <%- include('../partials/admin/sidebar') %>

        <main class="main-content max-w-5xl mx-auto">
            <h1 class="text-3xl font-bold mb-8">Add New Product</h1>

            <form action="/admin/products/add" method="POST" enctype="multipart/form-data" id="productForm">
                
                <div class="glass-card">
                    <label class="form-label">Product Name</label>
                    <input type="text" name="name" id="productName" class="input-field" placeholder="Enter product name">

                    <label class="form-label mt-6">Description</label>
                    <textarea name="description" id="productDescription" rows="4" class="input-field" placeholder="Describe your product..."></textarea>

                    <label class="form-label mt-6">Category</label>
                    <select name="category" class="input-field">
                        <% categories.forEach(cat=> { %>
                            <option value="<%= cat._id %>"><%= cat.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div id="variantsSection">
                    <div class="glass-card variant-card">
                        <label class="form-label">Color</label>
                        <select name="variants[0][color]" class="input-field color-select">
                            <option value="">Select Color</option>
                            <option>Black</option>
                            <option>White</option>
                            <option>Red</option>
                            <option>Blue</option>
                            <option>Silver</option>
                        </select>

                        <div class="grid grid-cols-2 gap-4 mt-6">
                            <div>
                                <label class="form-label">Regular Price</label>
                                <input type="number" name="variants[0][regularPrice]" placeholder="0.00" class="input-field reg-price" step="0.01">
                            </div>
                            <div>
                                <label class="form-label">Sale Price</label>
                                <input type="number" name="variants[0][salePrice]" placeholder="0.00" class="input-field sale-price" step="0.01">
                            </div>
                        </div>

                        <label class="form-label mt-6">Stock Quantity</label>
                        <input type="number" name="variants[0][quantity]" placeholder="0" class="input-field qty-field">

                        <label class="form-label mt-6">Product Images (At least 3 required)</label>
                        <div class="grid grid-cols-4 gap-4 mt-2">
                            <% for(let i=0; i < 4; i++) { %>
                                <div class="image-upload-box" id="box-v0-input-<%= i %>">
                                    <button type="button" class="img-delete-btn" onclick="deleteImage(event, 'v0-input-<%= i %>')">
                                        <i class="fas fa-times"></i>
                                    </button>
                                    <div class="w-full h-full flex items-center justify-center" onclick="document.getElementById('v0-input-<%= i %>').click()">
                                        <i class="fas fa-image text-neutral-600 text-xl icon-placeholder"></i>
                                    </div>
                                    <input type="file" id="v0-input-<%= i %>" name="variants[0][images]" class="hidden img-input" accept="image/*" onchange="initCropper(event, 'v0-input-<%= i %>')">
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <button type="button" onclick="addNewVariant()" class="w-full mb-8 py-3 border-2 border-dashed border-zinc-800 rounded-xl text-zinc-500 hover:text-white transition-all">
                    <i class="fas fa-plus mr-2"></i> Add New Color Variant
                </button>

                <div class="flex items-center justify-end gap-4 pb-10">
                    <a href="/admin/products" class="bg-zinc-800 hover:bg-zinc-700 text-white px-8 py-3 rounded-xl font-bold">Cancel</a>
                    <button type="submit" id="submitBtn" class="bg-blue-600 hover:bg-blue-700 text-white px-10 py-3 rounded-xl font-bold transition-all">
                        Add Product
                    </button>
                </div>
            </form>
        </main>
    </div>

    <div id="cropperModal">
        <div class="modal-content-wrapper">
            <h3 class="text-xl font-bold mb-4">Crop Image</h3>
            <div style="width:100%; height:400px; background:#000; border-radius:10px; overflow:hidden; margin-bottom:20px;">
                <img id="cropperImage" src="" style="max-width: 100%;">
            </div>
            <div class="flex justify-end gap-4">
                <button type="button" onclick="closeModal()" class="px-6 py-2 text-zinc-400">Cancel</button>
                <button type="button" onclick="cropImage()" class="px-8 py-2 bg-blue-600 rounded-lg font-bold">Save Crop</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <script>
        let cropper;
        let currentInputId;
        let variantCount = 1;

        function showError(msg) {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = "bg-red-600 text-white px-6 py-4 rounded-xl shadow-xl flex gap-4";
            toast.innerHTML = `<i class="fas fa-circle-exclamation text-xl"></i><div class="flex-1"><p class="text-sm font-medium">${msg}</p></div><button onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 5000);
        }

        function deleteImage(event, inputId) {
            event.stopPropagation();
            const input = document.getElementById(inputId);
            const box = document.getElementById(`box-${inputId}`);
            const deleteBtn = box.querySelector('.img-delete-btn');
            input.value = "";
            const displayArea = box.querySelector('div[onclick]');
            displayArea.innerHTML = `<i class="fas fa-image text-neutral-600 text-xl icon-placeholder"></i>`;
            deleteBtn.style.display = 'none';
        }

        // --- SUBMIT HANDLER ---
        document.getElementById("productForm").addEventListener("submit", function (e) {
            e.preventDefault();

            const name = document.getElementById('productName').value.trim();
            const desc = document.getElementById('productDescription').value.trim();
            const variantCards = document.querySelectorAll(".variant-card");

            if (!name) return showError("Product name is missing");
            if (desc.length < 10) return showError("Description should be at least 10 characters");

            for (let i = 0; i < variantCards.length; i++) {
                const color = variantCards[i].querySelector('.color-select').value;
                const regPrice = variantCards[i].querySelector('.reg-price').value;
                const salePrice = variantCards[i].querySelector('.sale-price').value;
                const qty = variantCards[i].querySelector('.qty-field').value;
                const images = variantCards[i].querySelectorAll('.img-input');

                if (!color) return showError(`Select color for variant ${i+1}`);
                if (!regPrice || parseFloat(regPrice) <= 0) return showError(`Invalid regular price for variant ${i+1}`);
                if (qty === "" || parseInt(qty) < 0) return showError(`Invalid quantity for variant ${i+1}`);
                
                if (salePrice !== "") {
                    if (parseFloat(salePrice) <= 0) return showError("Sale price must be greater than 0");
                    if (parseFloat(salePrice) >= parseFloat(regPrice)) return showError("Sale price must be lower than Regular price");
                }

                let hasImage = false;
                images.forEach(input => { if(input.files.length > 0) hasImage = true; });
                if(!hasImage) return showError(`Add at least one image for variant ${i+1}`);
            }

            const btn = document.getElementById('submitBtn');
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Adding...';
            btn.disabled = true;
            document.getElementById('successModal').style.display = 'flex';

            setTimeout(() => {
                this.submit();
            }, 1500);
        });

        function initCropper(event, id) {
            const input = event.target;
            if (input.files && input.files[0]) {
                const file = input.files[0];

                // --- IMAGE VALIDATION START ---
                if (!file.type.startsWith("image/")) {
                    showError("Invalid File: Only image files are allowed");
                    input.value = "";
                    return;
                }

                if (file.size > 2 * 1024 * 1024) {
                    showError("File Too Large: Image must be under 2MB");
                    input.value = "";
                    return;
                }
                // --- IMAGE VALIDATION END ---

                currentInputId = id;
                const reader = new FileReader();
                reader.onload = function (e) {
                    const modal = document.getElementById('cropperModal');
                    const image = document.getElementById('cropperImage');
                    image.src = e.target.result;
                    modal.style.display = 'flex';
                    if (cropper) cropper.destroy();
                    cropper = new Cropper(image, { aspectRatio: 1, viewMode: 1 });
                };
                reader.readAsDataURL(file);
            }
        }

        function closeModal() {
            document.getElementById('cropperModal').style.display = 'none';
            if (cropper) cropper.destroy();
        }

        function cropImage() {
            const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
            const input = document.getElementById(currentInputId);
            const box = document.getElementById(`box-${currentInputId}`);
            const deleteBtn = box.querySelector('.img-delete-btn');
            
            canvas.toBlob((blob) => {
                const file = new File([blob], `img-${Date.now()}.jpg`, { type: "image/jpeg" });
                const dataTransfer = new DataTransfer();
                dataTransfer.items.add(file);
                input.files = dataTransfer.files;

                const displayArea = box.querySelector('div[onclick]');
                displayArea.innerHTML = `<img src="${canvas.toDataURL('image/jpeg')}">`;
                deleteBtn.style.display = 'flex';
                closeModal();
            }, 'image/jpeg');
        }

        function addNewVariant() {
            const section = document.getElementById('variantsSection');
            const div = document.createElement('div');
            div.className = 'glass-card variant-card relative';
            let imgHtml = '';
            for (let i = 0; i < 4; i++) {
                const id = `v${variantCount}-input-${i}`;
                imgHtml += `
                    <div class="image-upload-box" id="box-${id}">
                        <button type="button" class="img-delete-btn" onclick="deleteImage(event, '${id}')">
                            <i class="fas fa-times"></i>
                        </button>
                        <div class="w-full h-full flex items-center justify-center" onclick="document.getElementById('${id}').click()">
                            <i class="fas fa-image text-neutral-600 text-xl icon-placeholder"></i>
                        </div>
                        <input type="file" id="${id}" name="variants[${variantCount}][images]" class="hidden img-input" accept="image/*" onchange="initCropper(event,'${id}')">
                    </div>`;
            }
            div.innerHTML = `
                <button type="button" onclick="this.parentElement.remove()" class="absolute top-4 right-4 text-zinc-500 hover:text-red-500"><i class="fas fa-trash"></i></button>
                <label class="form-label">Color</label>
                <select name="variants[${variantCount}][color]" class="input-field color-select"><option value="">Select Color</option><option>Black</option><option>White</option><option>Red</option><option>Blue</option></select>
                <div class="grid grid-cols-2 gap-4 mt-6">
                    <input type="number" name="variants[${variantCount}][regularPrice]" placeholder="Reg Price" class="input-field reg-price">
                    <input type="number" name="variants[${variantCount}][salePrice]" placeholder="Sale Price" class="input-field sale-price">
                </div>
                <input type="number" name="variants[${variantCount}][quantity]" placeholder="Quantity" class="input-field qty-field mt-6">
                <div class="grid grid-cols-4 gap-4 mt-4">${imgHtml}</div>`;
            section.appendChild(div);
            variantCount++;
        }
    </script>
</body>
</html>